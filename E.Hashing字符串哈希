// ==================================================================================
//                            字符串哈希 (String Hashing) 终极笔记
// ==================================================================================
// 核心哲学：把“复杂且庞大”的字符串，映射成一个“简单且唯一”的整数。
// 既然比较两个长字符串需要 O(L) 的时间，那比较两个整数只需要 O(1)。
// 只要两个字符串的哈希值不同，它们一定不同；如果哈希值相同，它们“极大概率”相同。
// ==================== 1. 核心定义与数理逻辑 ====================
// 适用范围：
//   1. 快速判断两个字符串是否相等 (O(1))。
//   2. 快速判断两个子串是否相等。
//   3. 最长公共子串 (LCS)、最长回文子串 (结合二分答案)。
// 核心思想 (多项式滚动哈希 Polynomial Rolling Hash)：
//   把字符串看作一个 P 进制数。
//   Hash(S) = (S[1]*P^{n-1} + S[2]*P^{n-2} + ... + S[n]*P^0) % M
// 常用参数 (玄学调参)：
//   P (进制基数): 131 或 13331 (经验值，冲突概率极低)。
//   M (模数): 
//     - 方案 A: 2^64 (利用 unsigned long long 自然溢出，省去取模操作，最快)。
//     - 方案 B: 1e9+7 或 1e9+9 (双哈希常用)。

#include <bits/stdc++.h>
using namespace std;

// ==================== 2. 模型一：自然溢出法 (单哈希标准模板) ====================
// 核心：利用 unsigned long long (ULL) 的范围 [0, 2^64-1]。
// 当计算结果超过最大值时，会自动对 2^64 取模。

typedef unsigned long long ULL; // 【关键】自动溢出 = 自动取模

// 【避坑】数组大小必须开够！通常 N=100000，开 100 必死。
const int N = 100010; 
const int P = 131; 

ULL h[N], p[N]; 
char s[N]; // 或者 string s

// 1. 预处理哈希值
// 建议：传入的字符串下标最好已经处理过（从 1 开始）
void init_hash(string& str, ULL h[], int n) {
    p[0] = 1;
    h[0] = 0;
    for (int i = 1; i <= n; i++) {
        p[i] = p[i-1] * P;
        h[i] = h[i-1] * P + str[i]; 
    }
}

// 2. O(1) 查询任意子串 s[l...r] 的哈希值
// 公式：Hash(l, r) = h[r] - h[l-1] * P^(len)
ULL get_hash(ULL h[], int l, int r) {
    return h[r] - h[l-1] * p[r - l + 1];
}

// ==================== 3. 模型二：哈希 + 二分答案 (最长公共子串) ====================
// 场景：求两个字符串 A 和 B 的最长公共子串长度。
// 核心：二分长度 mid，检查是否存在长度为 mid 的公共子串。
// 复杂度：O(N log^2 N) 或 O(N log N) 取决于实现。

string A, B;
ULL hA[N], hB[N];

// Check 函数：判断 A 和 B 是否有长度为 len 的公共子串
bool check(int len, int n1, int n2) {
    vector<ULL> v;
    
    // 1. 把 A 的所有长度为 len 的子串哈希存入 vector
    for (int i = 1; i + len - 1 <= n1; i++) {
        v.push_back(get_hash(hA, i, i + len - 1));
    }
    
    // 2. 排序 A 的哈希集合 (为了二分查找)
    sort(v.begin(), v.end());
    
    // 3. 遍历 B 的所有长度为 len 的子串
    for (int i = 1; i + len - 1 <= n2; i++) {
        ULL target = get_hash(hB, i, i + len - 1);
        
        // 4. 【关键逻辑】在 A 的集合里找 B 的元素
        // 使用 binary_search (O(log N)) 快速查找
        if (binary_search(v.begin(), v.end(), target)) {
            return true; // 找到了！
        }
    }
    return false;
}

void solve_LCS() {
    cin >> A >> B;
    
    // 【神技】下标对齐：强行加空格，让有效字符从下标 1 开始
    // 这样 A[1] 对应 hA[1]，彻底告别 i-1/i+1 的下标地狱
    A = " " + A;
    B = " " + B;
    
    int n1 = A.length() - 1;
    int n2 = B.length() - 1;
    
    init_hash(A, hA, n1);
    init_hash(B, hB, n2); // 注意：p 数组只需要初始化一次，或者共用
    
    int l = 0, r = min(n1, n2);
    int ans = 0;
    
    while (l <= r) {
        int mid = l + (r - l) / 2;
        if (mid == 0) { l = 1; continue; }
        
        if (check(mid, n1, n2)) {
            ans = mid;
            l = mid + 1; // 可行，尝试更长的
        } else {
            r = mid - 1; // 不行，缩短
        }
    }
    cout << ans << endl;
}

// ==================== 4. 模型三：双哈希 (Double Hash) ====================
// 痛点：单哈希容易被出题人卡 (如 Thue-Morse 序列)。
// 方案：用两套 (P, M) 同时计算，只有两个哈希值都相等才算相等。
//区别：双哈希和单哈希只有一个区别，即双哈希不再使用unsigned long long的自动溢出，自己去维护对应的基数的余数

struct DoubleHash {//重载运算符 双等号 小于号
    long long h1, h2;
    bool operator==(const DoubleHash &other) const {
        return h1 == other.h1 && h2 == other.h2;
    }
    bool operator<(const DoubleHash &other) const {
        if (h1 != other.h1) return h1 < other.h1;
        return h2 < other.h2;
    }
};

const long long M1 = 1e9 + 7, P1 = 131;
const long long M2 = 1e9 + 9, P2 = 13331;
long long H1[N], Pow1[N], H2[N], Pow2[N];

// 双哈希获取函数
DoubleHash get_double_hash(int l, int r) {
    // 注意：非自然溢出法，减法后必须 + Mod 再 % Mod，防止负数
    long long res1 = (H1[r] - H1[l-1] * Pow1[r-l+1] % M1 + M1) % M1;
    long long res2 = (H2[r] - H2[l-1] * Pow2[r-l+1] % M2 + M2) % M2;
    return {res1, res2};
}

// ==================== 5. 模型四：二维哈希 (2D Hashing) ====================
// 场景：矩阵匹配。例如：在大图 (N*M) 中找小图 (R*C) 出现了几次。
// 核心：
//   1. 先对每一行做哈希 (行哈希)。
//   2. 再对“行哈希值”构成的列做哈希 (列哈希)。
//   3. 维护两个进制 P (行) 和 Q (列)。

const int P_ROW = 131;   // 行进制
const int P_COL = 13331; // 列进制 (必须不同)
ULL h2d[1010][1010];     // 二维哈希数组
ULL p_row[1010], p_col[1010]; // 预处理幂次
char mat[1010][1010];    // 存储矩阵

// 初始化二维哈希
void init_2d_hash(int n, int m) {
    p_row[0] = 1; p_col[0] = 1;
    for (int i = 1; i <= max(n, m); i++) {
        p_row[i] = p_row[i-1] * P_ROW;
        p_col[i] = p_col[i-1] * P_COL;
    }

    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= m; j++) {
            // 步骤1：先算行的哈希 (横向)
            h2d[i][j] = h2d[i][j-1] * P_ROW + mat[i][j];
        }
    }
    
    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= m; j++) {
            // 步骤2：再叠加列的哈希 (纵向)
            // 注意：这里是在已有的行哈希基础上，乘列进制
            h2d[i][j] += h2d[i-1][j] * P_COL;
        }
    }
}

// 查询子矩阵哈希: 左上(x1, y1) -> 右下(x2, y2)
// 公式记忆：类似二维前缀和，但减去的部分要乘上对应的幂次 (厚度)
ULL get_sub_hash_2d(int x1, int y1, int x2, int y2) {
    int len_x = x2 - x1 + 1; // 高度
    int len_y = y2 - y1 + 1; // 宽度
    
    return h2d[x2][y2] 
         - h2d[x1-1][y2] * p_col[len_x]          // 减上面 (乘列幂)
         - h2d[x2][y1-1] * p_row[len_y]          // 减左边 (乘行幂)
         + h2d[x1-1][y1-1] * p_col[len_x] * p_row[len_y]; // 补左上
}

// ==================== 6. 模型五：树哈希 (Tree Hashing) ====================
// 场景：判断两棵树是否同构 (Isomorphism)。即：形状是否完全一样。
// 核心哲学：树的哈希 = 根节点的哈希。
// 递归定义：H(u) = 1 + sum( shift( H(v) ) )，其中 v 是 u 的子节点。
// 关键点：
//   1. 必须对子节点的哈希值进行【排序】，因为树的结构与子树顺序无关。
//   2. 使用 shift 混淆函数防止异或冲突。

// --- 基础工具 ---
vector<int> adj[N]; // 邻接表
ULL sub_hash[N];    // 记录以 u 为根的子树哈希

// 混淆函数 (SplitMix64 变种)，防止哈希碰撞
// 作用：打乱二进制位，让相似的数变得完全不同
ULL shift(ULL x) {
    x ^= x << 13;
    x ^= x >> 7;
    x ^= x << 17;
    return x;
}
const ULL MASK = 0x517cc1b727220a95; // 随机大质数掩码

// --- 模式 A：固定根哈希 (Rooted Tree Isomorphism) ---
//此处使用的位运算是按位异或，需要按位异或一个掩码
// 适用：题目指定了根节点，或者作为子程序使用
void get_rooted_hash(int u, int fa) {
    sub_hash[u] = 1; // 基础值，代表节点本身
    vector<ULL> child_hashes;
    
    for (int v : adj[u]) {
        if (v == fa) continue;
        get_rooted_hash(v, u);
        child_hashes.push_back(sub_hash[v]);
    }
    
    // 【核心】排序！消除子树顺序的影响（这里没有必要存在，不用写）
    sort(child_hashes.begin(), child_hashes.end());
    
    // 组合子节点哈希
    for (ULL h : child_hashes) {
        // 使用 shift(h ^ MASK) 进行混淆并累加
        sub_hash[u] += shift(h ^ MASK);
    }
}

// --- 模式 B：无根树哈希 (Unrooted Tree Isomorphism) ---
// 痛点：两棵同构的树，如果选的根不同，算出来的哈希值会不同。
// 方案：找到树的【重心 (Centroid)】作为根。
// 原理：一棵树的重心最多只有 2 个。我们以重心为根跑一次哈希，结果就是唯一的。
// 如果有两个重心，就跑两次取最小值（或都存下来）。

int sz[N], max_part[N]; // 重心相关数组
vector<int> centroids;  // 存储找到的重心

// 找重心 DFS
void get_centroid(int u, int fa, int total_nodes) {
    sz[u] = 1;
    max_part[u] = 0;
    for (int v : adj[u]) {
        if (v == fa) continue;
        get_centroid(v, u, total_nodes);
        sz[u] += sz[v];
        max_part[u] = max(max_part[u], sz[v]);
    }
    max_part[u] = max(max_part[u], total_nodes - sz[u]);
    
    // 如果最大连通块 <= n/2，则是重心
    if (max_part[u] <= total_nodes / 2) {
        centroids.push_back(u);
    }
}

// 获取无根树的唯一指纹
ULL get_unrooted_hash(int n) {
    centroids.clear();
    get_centroid(1, 0, n); // 1. 先找重心
    
    ULL res = ULLONG_MAX; // 存最小哈希值
    
    // 2. 分别以找到的重心为根，跑固定根哈希
    for (int root : centroids) {
        get_rooted_hash(root, 0);
        res = min(res, sub_hash[root]);
    }
    return res;
}

// ==================== 7. 避坑指南 (Blood & Tears) ====================
/*
1. 数组大小 (RE 之源)
   错误：int hash[100];
   修正：const int N = 100010; 必须开得比字符串最大长度大！

2. 数据类型 (WA 之源)
   错误：int hash[N]; -> 溢出变负数，逻辑崩坏。
   修正：必须用 unsigned long long (ULL)。

3. 下标对齐 (逻辑混乱之源)
   痛点：string 是 0-based，hash 习惯 1-based。
   神技：读入后 s = " " + s;
   这样 s[1] 就是第一个字符，和 hash[1] 完美对应，代码清爽度 +100%。

4. Check 函数的逻辑错误
   错误：把 A 和 B 的哈希放在一起排序找相邻相等。
        (这会把 A 内部的重复子串误判为 A 和 B 的公共子串)
   修正：A 做字典 (vector + sort)，B 去查字典 (binary_search)。

5. 负数取模 (针对双哈希/非自然溢出)
   C++ 中 (-5) % 3 = -2。
   公式必须写成：((a - b) % M + M) % M。
   
6. 二维哈希的进制
   错误：行和列使用相同的 P。
   修正：行用 131，列用 13331，防止对称矩阵冲突。

7. 树哈希细节
   - 排序：子节点哈希必须 sort，否则左子树和右子树交换会被判为不同。
   - 深度：如果树很深（链状），递归可能爆栈，需注意系统栈大小。
   - 异或坑：直接用 sum += (h[v] ^ MASK) 是不行的，因为异或满足交换律容易冲突，
            必须套一层 shift() 函数打乱位。
   - 无根树：不要随便选点当根，必须找重心（或者用换根 DP 算出所有点的哈希取最值）。
*/
