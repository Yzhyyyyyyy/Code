// ==================================================================================
//                            字符串哈希 (String Hashing) 笔记
// ==================================================================================
// 核心哲学：把“复杂且庞大”的字符串，映射成一个“简单且唯一”的整数。
// 既然比较两个长字符串需要 O(L) 的时间，那比较两个整数只需要 O(1)。
// 只要两个字符串的哈希值不同，它们一定不同；如果哈希值相同，它们“极大概率”相同。
// ==================== 1. 核心定义与数理逻辑 ====================
// 适用范围：
//   1. 快速判断两个字符串是否相等 (O(1))。
//   2. 快速判断两个子串是否相等。
//   3. 字符串匹配 (KMP 的暴力替代品)、最长回文子串、最长公共子串。
// 核心思想 (多项式滚动哈希 Polynomial Rolling Hash)：
//   把字符串看作一个 P 进制数。
//   Hash(S) = (S[1]*P^{n-1} + S[2]*P^{n-2} + ... + S[n]*P^0) % M
// 常用参数 (玄学调参)：
//   P (进制基数): 131 或 13331 (经验值，冲突概率极低)。
//   M (模数): 
//     - 方案 A: 2^64 (利用 unsigned long long 自然溢出，省去取模操作，最快)。
//     - 方案 B: 1e9+7 或 1e9+9 (双哈希常用)。
// ==================== 2. 模型一：自然溢出法 (单哈希) ====================
// 题目：P3370 【模板】字符串哈希
// 核心：利用 unsigned long long (ULL) 的范围 [0, 2^64-1]。
// 当计算结果超过最大值时，会自动对 2^64 取模。
// -------------------- 代码实现模板 --------------------
#include <bits/stdc++.h>
using namespace std;
typedef unsigned long long ULL; // 【关键】自动溢出 = 自动取模

const int MAXN = 10005;
const int P = 131; // 进制数，比字符集大小要大，通常选质数

// h[i] 表示前缀 s[1...i] 的哈希值
// p[i] 表示 P 的 i 次方 (P^i)
ULL h[MAXN], p[MAXN]; 
char s[MAXN];

// 1. 预处理哈希值
void init_hash(int n) {
    p[0] = 1;
    h[0] = 0;
    for (int i = 1; i <= n; i++) {
        // 预处理 P 的幂次
        p[i] = p[i-1] * P;
        // 核心转移：前缀哈希 = 前一位哈希 * P + 当前字符
        // 类似于十进制： "12" -> "123"  =>  12 * 10 + 3
        h[i] = h[i-1] * P + s[i]; 
    }
}

// 2. O(1) 查询任意子串 s[l...r] 的哈希值
// 公式推导：
//   h[r] = s[1]*P^{r-1} + ... + s[l]*P^{r-l} + ... + s[r]*P^0
//   h[l-1] = s[1]*P^{l-2} + ... + s[l-1]*P^0
//   我们想消去 s[1]...s[l-1] 的部分，需要把 h[l-1] 左移 (r-l+1) 位，即乘以 P^{r-l+1}
//   对齐后相减，剩下的就是 s[l...r] 的哈希值。
ULL get_hash(int l, int r) {
    return h[r] - h[l-1] * p[r-l+1];
}

// 3. 解决 P3370 (统计不同字符串个数)
void solve_P3370() {
    int N; cin >> N;
    vector<ULL> v;
    for(int i=0; i<N; i++) {
        cin >> (s+1); // 从下标 1 开始读入
        int len = strlen(s+1);
        init_hash(len);
        v.push_back(get_hash(1, len));
    }
    // 排序 + 去重
    sort(v.begin(), v.end());
    int ans = unique(v.begin(), v.end()) - v.begin();
    cout << ans << endl;
}
// ==================== 3. 模型二：双哈希 (Double Hash) ====================
// 题目：P5270 无论怎样神树大人都会删库跑路 (Anti-Hash 测试题)
// 痛点：单哈希（尤其是自然溢出）容易被出题人“卡”。
//      出题人可以构造特定的字符串（如 Thue-Morse 序列），使得 hash(A) == hash(B)。
// 解决方案：用两套不同的 (P, M) 组合计算两个哈希值。
//      只有当 hash1(A)==hash1(B) 且 hash2(A)==hash2(B) 时，才认为 A==B。
//      冲突概率从 1/M 降低到 1/(M1 * M2)，几乎不可能冲突。
// -------------------- 核心逻辑 --------------------
struct DoubleHash {
    long long h1, h2;
    // 重载 == 运算符，方便比较
    bool operator==(const DoubleHash &other) const {
        return h1 == other.h1 && h2 == other.h2;
    }
    // 重载 < 运算符，方便排序或放入 map
    bool operator<(const DoubleHash &other) const {
        if (h1 != other.h1) return h1 < other.h1;
        return h2 < other.h2;
    }
};

const long long M1 = 1e9 + 7, P1 = 131;
const long long M2 = 1e9 + 9, P2 = 13331;
long long H1[MAXN], Pow1[MAXN];
long long H2[MAXN], Pow2[MAXN];

void init_double(int n) {
    Pow1[0] = Pow2[0] = 1;
    for(int i=1; i<=n; i++) {
        Pow1[i] = (Pow1[i-1] * P1) % M1;
        Pow2[i] = (Pow2[i-1] * P2) % M2;
        H1[i] = (H1[i-1] * P1 + s[i]) % M1;
        H2[i] = (H2[i-1] * P2 + s[i]) % M2;
    }
}

DoubleHash get_double_hash(int l, int r) {
    long long res1 = (H1[r] - H1[l-1] * Pow1[r-l+1] % M1 + M1) % M1; // 注意负数取模
    long long res2 = (H2[r] - H2[l-1] * Pow2[r-l+1] % M2 + M2) % M2;
    return {res1, res2};
}
// ==================== 4. 模型三：哈希的应用与系统设计 ====================
// 题目：P5537 【XR-3】系统设计
// 场景：不仅是简单的字符串匹配，而是结合数据结构（线段树/平衡树）维护哈希。
// 常见操作：
//   1. 字符串拼接：Hash(A+B) = Hash(A) * P^{len(B)} + Hash(B)
//   2. 提取公共前缀 (LCP)：二分答案 + 哈希判断。
//      - 问题：求 S1 和 S2 的最长公共前缀长度。
//      - 思路：二分长度 len，检查 get_hash(S1, 1, len) == get_hash(S2, 1, len)。
//      - 复杂度：O(log N)。
//   3. 允许 k 次失配的匹配：
//      - 结合二分 + 哈希，跳过相同部分，定位不同字符，计数 k 次。

// ==================== 5. 避坑指南 (Blood & Tears) ====================
/*
1. 下标从 1 开始！
   习惯：字符串数组 s[MAXN] 最好从下标 1 开始存，s[0] 空着。
   原因：公式 get_hash(l, r) 中需要用到 h[l-1]。如果 l=0，会访问 h[-1] 导致越界。
   如果非要从 0 开始，代码里全是 if(l==0) 的特判，非常丑陋且容易错。

2. 负数取模的噩梦 (针对非自然溢出法)
   公式：h[r] - h[l-1] * p[...]
   在 C++ 中，(2 - 10) % 7 结果是 -1，而不是我们想要的 6。
   修正：(a - b) % M  -->  ((a - b) % M + M) % M。
   一定要加上 + M 再取模！

3. 字符集的值
   s[i] 的值不能为 0。
   如果 s[i] 映射为 0，那么 "ab" (1, 2) 和 "ab\0" (1, 2, 0) 的哈希值可能无法区分（取决于实现细节）。
   通常 char 直接转 int 没问题，因为 ASCII 码不为 0。

4. 什么时候用双哈希？
   - 简单的判重、Codeforces 这种不易被针对的场：单哈希 (unsigned long long) 足够，快且代码短。
   - 国内 OI 比赛、题目明确暗示“卡哈希”、或者 P5270 这种题目：必须双哈希。
   - 实在懒得写双哈希？可以试试随机模数或者随机基数 P (srand(time(0)))，让出题人没法提前构造数据。

5. 空间警告
   不要开太大！long long H[MAXN] 也是占内存的。
   如果是双哈希，记得数组要开两倍的量，或者用结构体封装。
*/
