// ==================================================================================
//                            字符串哈希 (String Hashing) 终极笔记
// ==================================================================================
// 核心哲学：把“复杂且庞大”的字符串，映射成一个“简单且唯一”的整数。
// 既然比较两个长字符串需要 O(L) 的时间，那比较两个整数只需要 O(1)。
// 只要两个字符串的哈希值不同，它们一定不同；如果哈希值相同，它们“极大概率”相同。
// ==================== 1. 核心定义与数理逻辑 ====================
// 适用范围：
//   1. 快速判断两个字符串是否相等 (O(1))。
//   2. 快速判断两个子串是否相等。
//   3. 最长公共子串 (LCS)、最长回文子串 (结合二分答案)。
// 核心思想 (多项式滚动哈希 Polynomial Rolling Hash)：
//   把字符串看作一个 P 进制数。
//   Hash(S) = (S[1]*P^{n-1} + S[2]*P^{n-2} + ... + S[n]*P^0) % M
// 常用参数 (玄学调参)：
//   P (进制基数): 131 或 13331 (经验值，冲突概率极低)。
//   M (模数): 
//     - 方案 A: 2^64 (利用 unsigned long long 自然溢出，省去取模操作，最快)。
//     - 方案 B: 1e9+7 或 1e9+9 (双哈希常用)。

#include <bits/stdc++.h>
using namespace std;

// ==================== 2. 模型一：自然溢出法 (单哈希标准模板) ====================
// 核心：利用 unsigned long long (ULL) 的范围 [0, 2^64-1]。
// 当计算结果超过最大值时，会自动对 2^64 取模。

typedef unsigned long long ULL; // 【关键】自动溢出 = 自动取模

// 【避坑】数组大小必须开够！通常 N=100000，开 100 必死。
const int N = 100010; 
const int P = 131; 

ULL h[N], p[N]; 
char s[N]; // 或者 string s

// 1. 预处理哈希值
// 建议：传入的字符串下标最好已经处理过（从 1 开始）
void init_hash(string& str, ULL h[], int n) {
    p[0] = 1;
    h[0] = 0;
    for (int i = 1; i <= n; i++) {
        p[i] = p[i-1] * P;
        h[i] = h[i-1] * P + str[i]; 
    }
}

// 2. O(1) 查询任意子串 s[l...r] 的哈希值
// 公式：Hash(l, r) = h[r] - h[l-1] * P^(len)
ULL get_hash(ULL h[], int l, int r) {
    return h[r] - h[l-1] * p[r - l + 1];
}

// ==================== 3. 模型二：哈希 + 二分答案 (最长公共子串) ====================
// 场景：求两个字符串 A 和 B 的最长公共子串长度。
// 核心：二分长度 mid，检查是否存在长度为 mid 的公共子串。
// 复杂度：O(N log^2 N) 或 O(N log N) 取决于实现。

string A, B;
ULL hA[N], hB[N];

// Check 函数：判断 A 和 B 是否有长度为 len 的公共子串
bool check(int len, int n1, int n2) {
    vector<ULL> v;
    
    // 1. 把 A 的所有长度为 len 的子串哈希存入 vector
    for (int i = 1; i + len - 1 <= n1; i++) {
        v.push_back(get_hash(hA, i, i + len - 1));
    }
    
    // 2. 排序 A 的哈希集合 (为了二分查找)
    sort(v.begin(), v.end());
    
    // 3. 遍历 B 的所有长度为 len 的子串
    for (int i = 1; i + len - 1 <= n2; i++) {
        ULL target = get_hash(hB, i, i + len - 1);
        
        // 4. 【关键逻辑】在 A 的集合里找 B 的元素
        // 使用 binary_search (O(log N)) 快速查找
        if (binary_search(v.begin(), v.end(), target)) {
            return true; // 找到了！
        }
    }
    return false;
}

void solve_LCS() {
    cin >> A >> B;
    
    // 【神技】下标对齐：强行加空格，让有效字符从下标 1 开始
    // 这样 A[1] 对应 hA[1]，彻底告别 i-1/i+1 的下标地狱
    A = " " + A;
    B = " " + B;
    
    int n1 = A.length() - 1;
    int n2 = B.length() - 1;
    
    init_hash(A, hA, n1);
    init_hash(B, hB, n2); // 注意：p 数组只需要初始化一次，或者共用
    
    int l = 0, r = min(n1, n2);
    int ans = 0;
    
    while (l <= r) {
        int mid = l + (r - l) / 2;
        if (mid == 0) { l = 1; continue; }
        
        if (check(mid, n1, n2)) {
            ans = mid;
            l = mid + 1; // 可行，尝试更长的
        } else {
            r = mid - 1; // 不行，缩短
        }
    }
    cout << ans << endl;
}

// ==================== 4. 模型三：双哈希 (Double Hash) ====================
// 痛点：单哈希容易被出题人卡 (如 Thue-Morse 序列)。
// 方案：用两套 (P, M) 同时计算，只有两个哈希值都相等才算相等。

struct DoubleHash {
    long long h1, h2;
    bool operator==(const DoubleHash &other) const {
        return h1 == other.h1 && h2 == other.h2;
    }
    bool operator<(const DoubleHash &other) const {
        if (h1 != other.h1) return h1 < other.h1;
        return h2 < other.h2;
    }
};

const long long M1 = 1e9 + 7, P1 = 131;
const long long M2 = 1e9 + 9, P2 = 13331;
long long H1[N], Pow1[N], H2[N], Pow2[N];

// 双哈希获取函数
DoubleHash get_double_hash(int l, int r) {
    // 注意：非自然溢出法，减法后必须 + Mod 再 % Mod，防止负数
    long long res1 = (H1[r] - H1[l-1] * Pow1[r-l+1] % M1 + M1) % M1;
    long long res2 = (H2[r] - H2[l-1] * Pow2[r-l+1] % M2 + M2) % M2;
    return {res1, res2};
}

// ==================== 5. 避坑指南 (Blood & Tears) ====================
/*
1. 数组大小 (RE 之源)
   错误：int hash[100];
   修正：const int N = 100010; 必须开得比字符串最大长度大！

2. 数据类型 (WA 之源)
   错误：int hash[N]; -> 溢出变负数，逻辑崩坏。
   修正：必须用 unsigned long long (ULL)。

3. 下标对齐 (逻辑混乱之源)
   痛点：string 是 0-based，hash 习惯 1-based。
   神技：读入后 s = " " + s;
   这样 s[1] 就是第一个字符，和 hash[1] 完美对应，代码清爽度 +100%。

4. Check 函数的逻辑错误
   错误：把 A 和 B 的哈希放在一起排序找相邻相等。
        (这会把 A 内部的重复子串误判为 A 和 B 的公共子串)
   修正：A 做字典 (vector + sort)，B 去查字典 (binary_search)。

5. 负数取模 (针对双哈希/非自然溢出)
   C++ 中 (-5) % 3 = -2。
   公式必须写成：((a - b) % M + M) % M。
*/
