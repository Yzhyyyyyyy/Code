// ==================================================================================
//                            Manacher 算法 终极笔记
//                              【线性求最长回文子串】
// ==================================================================================
// 核心哲学：利用回文的对称性，避免重复计算，将 O(N^2) 暴力优化到 O(N)。
// 核心变量：
//    s   : 原始字符串
//    t   : 插入分隔符后的新串 (奇偶统一处理)
//    p[] : 回文半径数组，p[i] 表示 t[i] 为中心的最长回文半径
//    r   : 当前已知的最右回文边界 (Right boundary)
//    c   : 取得最右边界时对应的回文中心 (Center)

#include <bits/stdc++.h>
using namespace std;

const int N = 2000010;
int p[N]; // 回文半径数组，开全局防止爆栈

// ==================== 0. 核心疑问澄清 (Soul Q&A) ====================
/*
  Q1: 为什么要插入分隔符？
  A:  原始字符串有奇偶回文两种情况，分别处理很麻烦。
      插入分隔符（如 '#'）后，所有回文都变成奇数长度，统一处理。
      例：
        原串:  "abba"   → 偶数回文
        新串: "#a#b#b#a#" → 以中间'#'为中心的奇数回文
        原串:  "aba"    → 奇数回文
        新串: "#a#b#a#"   → 以'b'为中心的奇数回文

  Q2: p[i] 和原串回文长度的关系是什么？
  A:  在插入分隔符后的新串 t 中，以 t[i] 为中心的回文半径为 p[i]。
      对应原串的回文长度 = p[i] - 1。
      例：新串 "#a#b#a#" 中，'b' 的 p[i]=4，原串回文长度 = 4-1 = 3。

  Q3: r 和 c 分别是什么，为什么需要它们？
  A:  r = 当前所有回文中，延伸到最右边的那个右端点。
      c = 取得 r 时对应的回文中心。
      作用：当处理新位置 i 时，如果 i 在 r 内，
      可以利用对称点 mirror = 2*c - i 的 p 值，直接得到 p[i] 的初始值，
      避免从头暴力扩展，这就是 O(N) 的关键！
*/

// ==================== 1. 预处理：插入分隔符 ====================
// 将原串 s 转化为新串 t，统一奇偶回文。
// 例："abc" → "#a#b#c#"
// 新串长度 = 2 * n + 1

string build(string s) {
    string t = "#";
    for (char c : s) {
        t += c;
        t += '#';
    }
    return t;
}

// ==================== 2. 核心：Manacher 主算法 ====================
// 输入原始字符串 s，返回最长回文子串长度。

int manacher(string s) {
    string t = build(s);   // 插入分隔符
    int n = t.length();
    
    int r = -1, c = -1;    // 初始最右边界和中心均无效
    int ans = 0;

    for (int i = 0; i < n; i++) {

        // ① 初始化 p[i]
        if (i < r) {
            // i 在当前最右回文覆盖范围内
            // mirror 是 i 关于 c 的对称点
            int mirror = 2 * c - i;
            // 利用对称性：p[i] 至少是 min(p[mirror], r-i)
            // 不能超过 r-i，否则越界到未知区域
            p[i] = min(p[mirror], r - i);
        } else {
            // i 在最右边界外，只能从 1 开始暴力扩
            p[i] = 1;
        }

        // ② 暴力向外扩展（从已知的 p[i] 继续尝试扩）
        while (i - p[i] >= 0 && i + p[i] < n && t[i - p[i]] == t[i + p[i]]) {
            p[i]++;
        }

        // ③ 更新最右边界 r 和对应中心 c
        if (i + p[i] - 1 > r) {
            r = i + p[i] - 1;
            c = i;
        }

        // ④ 更新答案（原串回文长度 = p[i] - 1）
        ans = max(ans, p[i] - 1);
    }

    return ans;
}

// ==================== 3. 避坑指南 ====================
/*
1. 分隔符选择
   分隔符必须是原串中不存在的字符（如 '#'），
   否则会产生错误的回文匹配。

2. p[i] 的含义
   p[i] 是"半径"，包含中心本身。
   所以 p[i] = 1 代表只有中心自己，回文长度为 0（对应分隔符）。
   原串回文长度 = p[i] - 1。

3. r 是右端点下标，不是半径
   r = i + p[i] - 1，更新时别写成 r = i + p[i]。

4. 初始 r = -1
   保证第一个字符 i=0 时，i < r 不成立，走暴力扩展分支，逻辑正确。
*/
