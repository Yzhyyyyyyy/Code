// ==================================================================================
//                        数位 DP (Digit DP) 核心笔记
// ==================================================================================
// 核心哲学：不要一个一个枚举，按"位"来统计，用 DP 记录已有的约束状态。
// 如果题目是 "统计 [1, N] 中满足条件的数有多少"，那就拆位做 DP。

// ==================== 1. 核心定义与适用场景 ====================
// 适用范围：
//   1. 统计 [L, R] 中满足某种数字条件的整数个数。
//   2. 条件与数字的"每一位"有关（如：不含某个数字、相邻位不同、数字和为某值）。
//   3. 数据范围很大（N 可达 10^18），暴力枚举不可行。

// 核心思想：
//   - 暴力：枚举 1 ~ N 的每个数，逐一判断。-> O(N) 必超时
//   - 数位 DP：把数字按位拆开，从高位到低位逐位填，
//              用 DP 记录"当前填到第几位、有哪些约束"。-> O(位数 * 状态数)

// 核心技巧：前缀转化
//   [L, R] 的答案 = f(R) - f(L-1)
//   只需要写一个 f(N) = 统计 [0, N] 中满足条件的数的个数。

// ==================== 2. 通用模板 ====================

// -------------------- 状态设计 --------------------
// dp[pos][state][tight][started]
//   pos     : 当前填到第几位（从高位到低位）
//   state   : 题目要求的核心状态（如数字和、上一位的值等）
//   tight   : 是否还在上界的约束下（true = 当前位不能超过 N 的对应位）
//   started : 是否已经填了非零位（处理前导零问题）

// -------------------- 记忆化搜索写法（推荐）--------------------
// 绝大多数数位 DP 用记忆化搜索写，比递推清晰很多。

#include <bits/stdc++.h>
using namespace std;

int digits[20];          // 存储 N 的每一位
int memo[20][STATE_MAX]; // 记忆化数组，tight=true 时不能缓存！

// pos   : 当前位
// state : 题目核心状态
// tight : 是否贴着上界
// started : 是否已经开始（处理前导零）
int dfs(int pos, int state, bool tight, bool started) {
    // 边界：所有位填完了
    if (pos < 0) {
        return started ? (state 满足条件 ? 1 : 0) : 0;
    }

    // 记忆化：只有 tight=false 时才能缓存
    // （tight=true 时上界不同，不能复用）
    if (!tight && memo[pos][state] != -1)
        return memo[pos][state];

    int limit = tight ? digits[pos] : 9; // 当前位最大能填几
    int res = 0;

    for (int d = 0; d <= limit; d++) {
        bool new_tight   = tight && (d == limit);
        bool new_started = started || (d != 0);
        int  new_state   = 更新状态(state, d, new_started);

        res += dfs(pos - 1, new_state, new_tight, new_started);
    }

    if (!tight) memo[pos][state] = res;
    return res;
}

long long f(long long N) {
    int len = 0;
    while (N > 0) {
        digits[len++] = N % 10;
        N /= 10;
    }
    // digits[len-1] 是最高位，digits[0] 是最低位
    memset(memo, -1, sizeof(memo));
    return dfs(len - 1, 初始状态, true, false);
}

long long solve(long long L, long long R) {
    return f(R) - f(L - 1);
}

// ==================== 3. 经典例题：Windy 数 (P2657) ====================
// 题意：统计 [L, R] 中，相邻两位之差的绝对值 >= 2 的整数个数。
// 状态：上一位填了什么数字（用于判断差值）

int memo_windy[12][10]; // memo[pos][last_digit]

int dfs_windy(int pos, int last, bool tight, bool started) {
    if (pos < 0) return 1; // 填完了，合法

    if (!tight && started && memo_windy[pos][last] != -1)
        return memo_windy[pos][last];

    int limit = tight ? digits[pos] : 9;
    int res = 0;

    for (int d = 0; d <= limit; d++) {
        // 如果已经开始填数，检查相邻差
        if (started && abs(d - last) < 2) continue; // 不合法，跳过

        res += dfs_windy(pos - 1, d, tight && (d == limit), started || d != 0);
    }

    if (!tight && started) memo_windy[pos][last] = res;
    return res;
}

// ==================== 4. 经典例题：数字计数 (P2602) ====================
// 题意：统计 [L, R] 中，数字 0~9 各出现了多少次。
// 状态：当前统计的目标数字 x，以及已经出现了多少次

// 对每个数字 x 分别跑一次数位 DP
// state = 数字 x 出现的次数

long long memo_count[13][13]; // memo[pos][cnt]

long long dfs_count(int pos, int cnt, int x, bool tight, bool started) {
    if (pos < 0) return cnt; // 返回出现次数，不是返回 0/1

    if (!tight && started && memo_count[pos][cnt] != -1)
        return memo_count[pos][cnt];

    int limit = tight ? digits[pos] : 9;
    long long res = 0;

    for (int d = 0; d <= limit; d++) {
        int new_cnt = cnt;
        if (started || d != 0) { // 排除前导零
            if (d == x) new_cnt++;
        }
        res += dfs_count(pos - 1, new_cnt, x, tight && (d == limit), started || d != 0);
    }

    if (!tight && started) memo_count[pos][cnt] = res;
    return res;
}

// ==================== 5. 避坑指南 (Blood & Tears) ====================
/*
   1. tight=true 时绝对不能记忆化！
      - 因为 tight=true 时，当前位的上界是 digits[pos]，不同数字 N 会不同。
      - 只有 tight=false 时，状态才是"自由的"，可以复用。

   2. 前导零的处理：
      - started=false 表示还没填过非零位，这时候填 0 不算"真正的 0"。
      - 比如数字 007，前两个 0 是前导零，不算在数字里。
      - 很多状态在 started=false 时要特殊处理（如 last_digit 不能约束第一位）。

   3. digits 数组的方向：
      - 建议存成 digits[0] = 最低位，digits[len-1] = 最高位。
      - dfs 从 pos=len-1 开始往下填，pos=0 时填最低位。
      - 方向搞反了，结果就全错了。

   4. 答案类型：
      - 统计"个数"时返回 int/long long。
      - 统计"出现次数之和"时返回 long long（N 可达 10^18，次数也很大）。

   5. f(L-1) 的边界：
      - 当 L=0 时，f(L-1) = f(-1)，要特判返回 0。
      - 或者直接让 f(0) = 0（0 本身通常不满足条件）。
*/
