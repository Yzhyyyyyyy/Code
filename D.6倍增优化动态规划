// ==================================================================================
//                            倍增优化 DP (Doubling DP) 终极笔记
// ==================================================================================
// 核心哲学：不要一步一步走，要 1, 2, 4, 8... 这样跳着走。
// 既然 2^j = 2^{j-1} + 2^{j-1}，那么跳 2^j 步 等于 连续跳两次 2^{j-1} 步。

// ==================== 1. 核心定义与适用场景 ====================
// 适用范围：
//   1. 状态转移图是静态的（或者是树形结构）。
//   2. 步数非常大（比如 10^9 步），或者需要快速查询路径信息。
//   3. 满足结合律：从 A 走到 B，再从 B 走到 C，可以合并为 A 走到 C。

// 核心状态：
//   dp[u][i] -> 从 u 出发，进行了 2^i 步操作后到达的状态/位置。
//   val[u][i] -> 从 u 出发，进行了 2^i 步操作累计的代价/最大值/最小值。

// 状态转移方程（通用）：
//   dp[u][i] = dp[ dp[u][i-1] ][ i-1 ]
//   解释：从 u 走 2^i 步 = 先走 2^{i-1} 到达中转点 temp，再从 temp 走 2^{i-1} 步。

// ==================== 2. 模型一：图上的快速幂 (P1613 跑路) ====================
// 题目大意：每 1 秒可以移动 2^k 个单位距离。求从 A 到 B 的最短时间。
// 难点：把“距离”转化为“连通性”。
// 思路：预处理出所有距离为 2^k 的两点，在它们之间连一条权值为 1 的边，跑 BFS/Floyd。

#include <iostream>
#include <cstring>
#include <algorithm>
using namespace std;

// g[i][j][k] 表示：从 i 到 j 是否存在一条长度为 2^k 的路径
bool g[55][55][65]; 
int dist[55][55];   // 最终的最短路图
int n_run, m_run;

void solve_running() {
    memset(dist, 0x3f, sizeof(dist));
    
    // 1. 初始化：读入边，距离为 2^0 = 1
    // for (edges) { g[u][v][0] = true; dist[u][v] = 1; }

    // 2. 倍增预处理连通性 (类似 Floyd)
    // 注意：k (幂次) 必须在最外层！
    for (int k = 1; k <= 64; k++) { 
        for (int i = 1; i <= n_run; i++) {
            for (int t = 1; t <= n_run; t++) { // 中转点
                for (int j = 1; j <= n_run; j++) {
                    // 如果 i->t 有 2^{k-1} 且 t->j 有 2^{k-1}
                    // 那么 i->j 就有 2^k
                    if (g[i][t][k-1] && g[t][j][k-1]) {
                        g[i][j][k] = true;
                        dist[i][j] = 1; // 关键：题目说跑 2^k 距离只需要 1 秒
                    }
                }
            }
        }
    }

    // 3. 跑一遍 Floyd 或 BFS 求最短路
    // ... 标准 Floyd 代码 ...
}

// ==================== 3. 模型二：树上倍增 & LCA (基础) ====================
// 这是倍增 DP 的基石。
// f[u][i] 表示 u 的第 2^i 个祖先。

int f[100005][20]; // 2^20 > 10^6
int depth[100005];

void init_lca(int u, int father) {
    depth[u] = depth[father] + 1;
    f[u][0] = father; // 2^0 = 1代祖先就是父节点

    for (int i = 1; i < 20; i++) {
        // 核心转移：我的 2^i 祖先 = 我的 2^{i-1} 祖先的 2^{i-1} 祖先
        f[u][i] = f[f[u][i-1]][i-1];
    }
    
    for (auto v : adj[u]) {
        if (v != father) init_lca(v, u);
    }
}

// ==================== 4. 模型三：复杂状态转移 (P1081 开车旅行) ====================
// 题目大意：A 和 B 轮流开车，A 走离当前最近的第二近城市，B 走最近的城市。
// 难点：
//   1. 预处理每个人在每个点会去哪 (利用 set 或 双向链表)。
//   2. 状态里要分 A 开车和 B 开车，或者把“A走一步+B走一步”看作一轮。
// 状态：
//   f[u][i] -> 从 u 出发，两人轮流开了 2^i 轮 (即 A走2^i步, B走2^i步) 后到达的城市。
//   da[u][i] -> 从 u 出发，2^i 轮中 A 行驶的总路程。
//   db[u][i] -> 从 u 出发，2^i 轮中 B 行驶的总路程。

const int MAXN = 100005;
int go[MAXN][2]; // go[u][0] 是 B 的目标(最近), go[u][1] 是 A 的目标(次近)
int f_drive[MAXN][20]; // 2^i 轮后的位置
long long da[MAXN][20], db[MAXN][20]; // 路程和

void solve_drive() {
    // 1. 预处理 go[u][0] 和 go[u][1] (利用 set 找前驱后继，略)

    // 2. 初始化 i=0 (即 2^0 = 1 轮)
    // 一轮定义为：A 先走一步，B 再走一步
    for (int i = 1; i <= n; i++) {
        int mid = go[i][1]; // A 先走
        int end = go[mid][0]; // B 再走
        
        f_drive[i][0] = end;
        da[i][0] = dist(i, mid);
        db[i][0] = dist(mid, end);
    }

    // 3. 倍增递推
    // 注意：p 代表幂次，必须在外层
    for (int p = 1; p < 20; p++) {
        for (int u = 1; u <= n; u++) {
            // 位置转移：跳 2^p 轮 = 跳 2^{p-1} 轮，再跳 2^{p-1} 轮
            int mid = f_drive[u][p-1];
            f_drive[u][p] = f_drive[mid][p-1];

            // 代价累加
            da[u][p] = da[u][p-1] + da[mid][p-1];
            db[u][p] = db[u][p-1] + db[mid][p-1];
        }
    }

    // 4. 查询 (拼凑法)
    // 给定最大距离 X，我们要尽可能多地跳，只要总距离不超过 X
    // 从大到小枚举 p (类似二进制拆分)
    // if (current_dist + da[...] + db[...] <= X) { 跳过去; }
}

// ==================== 5. 模型四：动态 DP / 矩阵倍增 (P5024 保卫王国) ====================
// 题目大意：树上独立集问题，但带修改，且多次询问“如果强制选u不选v”的最小代价。
// 标签：虽然归类在倍增，但 P5024 的正解通常是 "动态 DP (DDP)" = 树链剖分 + 矩阵乘法。
// 关联：矩阵乘法本身具有结合律，可以用倍增思想维护。

/*
  简单思路指引：
  1. 普通树形 DP：dp[u][0] 不选 u, dp[u][1] 选 u。
  2. 转移方程本质上是 (min, +) 矩阵乘法。
  3. 利用倍增（或者重链剖分的数据结构），维护从 u 到 根节点（或链顶）的矩阵积。
  4. 当修改一个点时，只影响它到根路径上的矩阵积，利用倍增/线段树快速更新。
  
  (代码过于复杂，作为倍增笔记仅做概念提及：倍增不仅可以维护位置，还可以维护“转移矩阵”)
