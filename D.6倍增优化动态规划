// ==================================================================================
//                            倍增优化 DP (Doubling DP) 终极笔记
// ==================================================================================
// 核心哲学：不要一步一步走，要 1, 2, 4, 8... 这样跳着走。
// 既然 2^j = 2^{j-1} + 2^{j-1}，那么跳 2^j 步 等于 连续跳两次 2^{j-1} 步。

// ==================== 1. 核心定义与适用场景 ====================
// 适用范围：
//   1. 状态转移图是静态的（或者是树形结构）。
//   2. 步数非常大（比如 10^9 步），或者需要快速查询路径信息。
//   3. 满足结合律：从 A 走到 B，再从 B 走到 C，可以合并为 A 走到 C。

// 核心状态 (根据你的习惯，层数 i 放第一维)：
//   fa[i][u] -> 从 u 出发，进行了 2^i 步操作后到达的状态/位置。
//   val[i][u] -> 从 u 出发，进行了 2^i 步操作累计的代价/最大值/最小值。

// 状态转移方程（通用）：
//   fa[i][u] = fa[i-1][ fa[i-1][u] ]
//   解释：从 u 走 2^i 步 = 先走 2^{i-1} 到达中转点 temp，再从 temp 走 2^{i-1} 步。

// ==================== 2. 模型一：图上的快速幂 (P1613 跑路) ====================
// 题目大意：每 1 秒可以移动 2^k 个单位距离。求从 A 到 B 的最短时间。
// 难点：把“距离”转化为“连通性”。
// 思路：预处理出所有距离为 2^k 的两点，在它们之间连一条权值为 1 的边，跑 BFS/Floyd。

#include <bits/stdc++.h>
using namespace std;

// g[k][i][j] 表示：从 i 到 j 是否存在一条长度为 2^k 的路径
// 你的习惯：层数 k 放第一维
bool g[65][55][55]; 
int dist[55][55];   // 最终的最短路图
int n, m;

void solve_running() {
    memset(dist, 0x3f, sizeof(dist));
    
    // 1. 初始化：读入边，距离为 2^0 = 1
    // for (edges) { g[0][u][v] = true; dist[u][v] = 1; }

    // 2. 倍增预处理连通性 (类似 Floyd)
    // 注意：k (幂次) 必须在最外层！
    for (int k = 1; k <= 64; k++) { 
        for (int i = 1; i <= n; i++) {
            for (int t = 1; t <= n; t++) { // 中转点
                for (int j = 1; j <= n; j++) {
                    // 如果 i->t 有 2^{k-1} 且 t->j 有 2^{k-1}
                    // 那么 i->j 就有 2^k
                    if (g[k-1][i][t] && g[k-1][t][j]) {
                        g[k][i][j] = true;
                        dist[i][j] = 1; // 关键：题目说跑 2^k 距离只需要 1 秒
                    }
                }
            }
        }
    }

    // 3. 跑一遍 Floyd 或 BFS 求最短路
    // ... 标准 Floyd 代码 ...
}

// ==================== 3. 模型二：树上倍增 & LCA (基础) ====================
// 这是倍增 DP 的基石。
// fa[i][u] 表示 u 的第 2^i 个祖先。

const int MAXN = 500005; // 记得开够大！
vector<int> boss[MAXN];
int fa[32][MAXN]; // 你的习惯：层数在前
int depth[MAXN];

void dfs(int from, int father, int deep) {
    fa[0][from] = father; // 2^0 = 1代祖先就是父节点
    depth[from] = deep;
    
    for (int i : boss[from]) {
        if (i != father) {
            dfs(i, from, deep + 1);
        }
    }
}

// 预处理倍增数组
void init_lca(int n) {
    // 外层循环必须是层数 i
    for (int i = 1; i < 32; i++) {
        for (int j = 1; j <= n; j++) {
            // 核心转移：我的 2^i 祖先 = 我的 2^{i-1} 祖先的 2^{i-1} 祖先
            fa[i][j] = fa[i-1][ fa[i-1][j] ];
        }
    }
}

// LCA 查询 (你的 gap 写法)
int lca(int x, int y) {
    if (depth[x] < depth[y]) swap(x, y); // 保证 x 深
    
    int gap = depth[x] - depth[y];
    
    // 1. 让 x 跳到和 y 同一层
    if (gap > 0) {
        for (int i = 31; i >= 0; i--) {
            if (((gap >> i) & 1) == 1)
                x = fa[i][x];
        }
    }

    if (x == y) return x;

    // 2. 一起往上跳
    for (int i = 31; i >= 0; i--) {
        if (fa[i][x] != fa[i][y]) {
            x = fa[i][x];
            y = fa[i][y];
        }
    }
    return fa[0][x];
}

// ==================== 4. 模型三：复杂状态转移 (P1081 开车旅行) ====================
// 题目大意：A 和 B 轮流开车，A 走离当前最近的第二近城市，B 走最近的城市。
// 难点：
//   1. 预处理每个人在每个点会去哪 (利用 set 或 双向链表)。
//   2. 状态里要分 A 开车和 B 开车，或者把“A走一步+B走一步”看作一轮。
// 状态：
//   fa[i][u] -> 从 u 出发，两人轮流开了 2^i 轮 (即 A走2^i步, B走2^i步) 后到达的城市。
//   da[i][u] -> 从 u 出发，2^i 轮中 A 行驶的总路程。
//   db[i][u] -> 从 u 出发，2^i 轮中 B 行驶的总路程。

int fa_drive[20][MAXN]; // 2^i 轮后的位置 (层数在前)
long long da[20][MAXN], db[20][MAXN]; // 路程和

void solve_drive(int n) {
    // 1. 预处理 go[u][0] 和 go[u][1] (利用 set 找前驱后继，略)

    // 2. 初始化 i=0 (即 2^0 = 1 轮)
    // 一轮定义为：A 先走一步，B 再走一步
    for (int i = 1; i <= n; i++) {
        // int mid = ...; int end = ...;
        // fa_drive[0][i] = end;
        // da[0][i] = ...;
        // db[0][i] = ...;
    }

    // 3. 倍增递推
    // 注意：p 代表幂次，必须在外层
    for (int p = 1; p < 20; p++) {
        for (int u = 1; u <= n; u++) {
            // 位置转移：跳 2^p 轮 = 跳 2^{p-1} 轮，再跳 2^{p-1} 轮
            int mid = fa_drive[p-1][u];
            fa_drive[p][u] = fa_drive[p-1][mid];

            // 代价累加
            da[p][u] = da[p-1][u] + da[p-1][mid];
            db[p][u] = db[p-1][u] + db[p-1][mid];
        }
    }

    // 4. 查询 (拼凑法)
    // 给定最大距离 X，我们要尽可能多地跳，只要总距离不超过 X
    // 从大到小枚举 p (类似二进制拆分)
