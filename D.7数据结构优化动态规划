// ==================================================================================
//                        数据结构优化 DP (DS Optimized DP) 终极笔记
// ==================================================================================
// 核心哲学：拒绝 O(N) 回头看，使用 O(log N) "上帝视角" 查索引。
// 如果 DP 转移方程是 "在满足条件的 j 中找最值"，那就把 j 扔进线段树里。

// ==================== 1. 核心定义与适用场景 ====================
// 适用范围：
//   1. 转移方程形如 dp[i] = max/min/sum(dp[j]) + val[i]。
//   2. j 的取值范围是一个"区间" (如 i-k <= j < i) 或 "值域" (如 a[j] < a[i])。
//   3. 或者是 树形 DP 带修改 (动态 DP)。

// 核心思想：
//   - 朴素 DP：为了算 dp[i]，遍历 j = 0...i-1。 -> O(N^2)
//   - DS 优化：每算出一个 dp[j]，就 update 到数据结构中。
//             算 dp[i] 时，直接 query 数据结构。 -> O(N log N)

// ==================== 2. 模型一：值域/区间索引 (LIS 进阶版) ====================
// 典型题目：P3287 方伯伯的玉米田 (二维 LIS)
// 适用场景：条件与数值大小有关，或者是在二维平面上找左下角的最优值。

// -------------------- 核心逻辑 --------------------
// 朴素方程：dp[i][j] = max(dp[x][y]) + 1，其中 x < i 且 y <= j (二维偏序)
// 优化手段：二维树状数组 (2D BIT) 或 降维打击 (排序一维 + 线段树另一维)。

#include <bits/stdc++.h>
using namespace std;

const int MAXN = 10005;
const int MAX_VAL = 5505; // 值域大小
int tree[MAX_VAL][MAX_VAL]; // 二维树状数组
int n, k;
int a[MAXN];
int dp[MAXN][505]; // dp[i][j] 前 i 个玉米，拔高 j 次

// 二维 BIT 修改：在 (x, y) 位置更新最大值 v
void update(int x, int y, int v) {
    for (int i = x; i <= k + 1; i += i & -i) { // 注意边界
        for (int j = y; j <= MAX_VAL; j += j & -j) {
            tree[i][j] = max(tree[i][j], v);
        }
    }
}

// 二维 BIT 查询：查询 (x, y) 左下角区域的最大值
int query(int x, int y) {
    int res = 0;
    for (int i = x; i > 0; i -= i & -i) {
        for (int j = y; j > 0; j -= j & -j) {
            res = max(res, tree[i][j]);
        }
    }
    return res;
}

// 核心流程
void solve_corn() {
    // 这里的 DP 甚至不需要显式数组，直接边算边存
    int ans = 0;
    for (int i = 1; i <= n; i++) {
        for (int j = k; j >= 0; j--) { // 类似背包，倒序枚举次数
            // 查询：拔高 j 次后，高度为 a[i]+j，我们要找拔高次数 <= j 且 高度 <= a[i]+j 的最大前驱
            int val = query(j + 1, a[i] + j) + 1;
            
            // 更新：把当前状态扔进 BIT
            update(j + 1, a[i] + j, val);
            ans = max(ans, val);
        }
    }
}

// ==================== 3. 模型二：线段树优化费用 (贡献提前计算) ====================
// 典型题目：P2605 [ZJOI2010] 基站选址
// 难点：Cost(i, j) 很难快速算。
// 核心 Trick：扫描线思想。
//    当我们从 i 枚举到 i+1 时，有些村庄的赔偿范围结束了，
//    我们就把这个村庄的赔偿金，加到它"能覆盖到的左边界"之前的所有 dp 值上。

// -------------------- 核心代码片段 --------------------
// SegTree 维护的是：dp[j] + cost(j, i) 的值
// 其中 dp[j] 是定值，cost(j, i) 随着 i 增大而动态变化。

struct Node { int min_val, lazy; } tr[MAXN * 4];

void build(int u, int l, int r, int k) { // 构建上一层的 dp 值
    if (l == r) {
        tr[u].min_val = dp[k][l]; // 上一轮 (k) 的 dp 值
        return;
    }
    // ... 标准 build ...
}

// 区间加法：把 cost 加到对应的 dp[j] 上
void modify(int u, int l, int r, int ql, int qr, int v) {
    if (ql <= l && r <= qr) {
        tr[u].min_val += v;
        tr[u].lazy += v;
        return;
    }
    // ... 标准 pushdown + 递归 ...
}

void solve_base_station() {
    for (int i = 1; i <= k; i++) { // 建第 i 个基站
        build(1, 0, n, i - 1); // 用上一轮 DP 初始化线段树
        
        for (int j = 1; j <= n; j++) {
            // 扫描线：走到 j 了
            // 处理所有"右边界"在 j 的村庄 p
            for (auto p : end_at[j]) {
                // 如果上一个基站建在 [1, st[p]-1] 之间，村庄 p 就覆盖不到了，需要赔偿 w[p]
                // 所以给线段树区间 [1, st[p]-1] 加上 w[p]
                if (st[p] > 1) 
                    modify(1, 0, n, 1, st[p] - 1, w[p]); 
            }
            // dp[i][j] = min_{0<=t<j} (dp[i-1][t] + cost(t, j)) + C[j]
            // 线段树维护的就是括号里的东西！
            dp[i][j] = query(1, 0, n, 1, j - 1) + C[j];
        }
    }
}

// ==================== 4. 模型三：动态 DP (Dynamic DP / DDP) ====================
// 典型题目：P4719 【模板】动态dp
// 适用场景：树形 DP + 带点权修改。
// 核心武器：树链剖分 (HLD) + 广义矩阵乘法 (Matrix Multiplication)。

// -------------------- 理论基础 --------------------
// 普通树 DP 方程：dp[u][0] = sum(max(dp[v][0], dp[v][1]))
//               dp[u][1] = val[u] + sum(dp[v][0])
// 
// 树剖后，我们将轻儿子的贡献记为 g[u]，重儿子的贡献保留在矩阵里。
// g[u][0] = sum(max(dp[light_v][0], dp[light_v][1]))
// g[u][1] = val[u] + sum(dp[light_v][0])
//
// 矩阵转移 (定义乘法 * 为 (max, +) 运算)：
// | dp[u][0] |   | g[u][0]   g[u][0] |   | dp[son][0] |
// |          | = |                   | * |            |
// | dp[u][1] |   | g[u][1]    -INF   |   | dp[son][1] |
//
// 只要维护重链上的矩阵连乘积，就能算出链顶的 DP 值！

// -------------------- 代码实现 --------------------

// 1. 定义广义矩阵乘法 (Max-Plus Algebra)
struct Matrix {
    int mat[2][2];
    Matrix() { memset(mat, -0x3f, sizeof(mat)); } // 初始化为极小值
    
    // 重载乘法：C[i][j] = max(A[i][k] + B[k][j])
    Matrix operator * (const Matrix &b) const {
        Matrix c;
        for (int i = 0; i < 2; i++)
            for (int j = 0; j < 2; j++)
                for (int k = 0; k < 2; k++)
                    c.mat[i][j] = max(c.mat[i][j], mat[i][k] + b.mat[k][j]);
        return c;
    }
};

// 2. 线段树维护矩阵积
// val[u] 存储的是节点 u 的构造矩阵 (包含轻儿子贡献 g[u])
Matrix val[MAXN * 4]; 

void update_matrix(int u, int l, int r, int pos, Matrix m) {
    if (l == r) {
        val[u] = m; // 单点修改矩阵
        return;
    }
    // ... 标准 update ...
    // pushup: 父节点矩阵 = 左儿子矩阵 * 右儿子矩阵 (注意顺序！！)
    // 这里的顺序取决于你的矩阵定义 (左乘还是右乘)，通常是 Right * Left
    val[u] = val[u<<1] * val[u<<1|1]; 
}

