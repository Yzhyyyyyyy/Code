// ==================================================================================
//                            KMP 算法 (Knuth-Morris-Pratt) 终极笔记
//                                  【1-based 竞赛通用版】
// ==================================================================================
// 核心哲学：永不回头 (Don't Look Back)。
// 核心变量：
//    s: 文本串 (主串)
//    p: 模式串 (子串)
//    ne[]: next 数组
//    i: 扫描指针 (永远往前走)
//    j: 匹配长度 (也是回退指针)

#include <bits/stdc++.h>
using namespace std;

const int N = 1000010;
int ne[N]; // next 数组，开在全局防止爆栈

// ==================== 0. 核心疑问澄清 (Soul Q&A) ====================
/*
  Q1: 为什么比较时是用 s[i] 去匹配 p[j+1]？不应该是下一位对下一位吗？
  A:  因为时间点不同步！
      - 循环开始时，i 刚刚 +1，s[i] 是“新来的”字符（当前位）。
      - 但 j 还是“上一轮”的值，代表“过去”已经匹配成功的长度。
      - 所以逻辑是：拿着“文本串的新字符 s[i]”，去挑战“模式串的下一关 p[j+1]”。
      - 只有挑战成功了，j 才会 +1。

  Q2: 0-based 和 1-based 中，j 到底指向哪里？
  A:  j 的定义永远是“已经匹配的长度”，但在下标指向上的含义完全不同：
      - 【1-based】(推荐):
        j = 3 代表匹配了 "ABC"。
        此时 j 指向下标 3 ('C')。也就是“刚刚匹配完的那一位”。
        下一位是 j+1 (下标 4)。逻辑：当前(j) -> 下一步(j+1)。直观！
      - 【0-based】(原生):
        j = 3 代表匹配了 "ABC" (下标 0,1,2)。
        此时 j 指向下标 3 (是'C'后面的那个字符)。
        也就是 j 直接指向了“下一位”。逻辑：长度 j = 下一位下标 j。容易晕！

  Q3: 为什么 buildNext 中 i 从 2 开始，而 kmpSearch 中 i 从 1 开始？
  A:  目的不同。
      - buildNext (找规律): 拿后缀匹配前缀。
        ne[1] 肯定是 0 (一个字符没有前后缀)。必须至少有两个字符才能开始比，所以从 2 开始。
      - kmpSearch (做匹配): 地毯式搜索。
        文本串的第 1 个字符也可能是模式串的起点，绝不能跳过，所以从 1 开始。
*/

// ==================== 1. 必读：0-based vs 1-based 的区别 ====================
/*
  【0-based (C++原生)】              【1-based (竞赛推荐)】
  ----------------------------------------------------------------------
  字符串处理:  直接用 string s           加空格: s = " " + s;
  下标范围:    0 ~ len-1                1 ~ len
  比较逻辑:    s[i] == p[j]             s[i] == p[j+1]  <-- 核心区别！
  回退逻辑:    j = ne[j-1]              j = ne[j]       <-- 1-based 更干净
  Next含义:    ne[i]对应 p[0...i]       ne[i]对应 p[1...i]

  ★ 为什么推荐 1-based？
  1. 回退时不用写 j-1，直接 ne[j]，不容易越界。
  2. 比较时用 p[j+1]，符合“拿当前位 s[i] 匹配下一位”的直觉。
*/

// ==================== 2. 核心定义：Next 数组 ====================
// 定义：ne[i] 表示模式串 p[1...i] 中，
//       【最长相等真前缀】和【最长相等真后缀】的长度。
// 举例：p = " ABABA" (注意前面有个空格)
//   i=1 ("A"):     ne[1] = 0
//   i=2 ("AB"):    ne[2] = 0
//   i=3 ("ABA"):   前缀"A", 后缀"A", ne[3] = 1
//   i=4 ("ABAB"):  前缀"AB", 后缀"AB", ne[4] = 2
//   i=5 ("ABABA"): 前缀"ABA", 后缀"ABA", ne[5] = 3

// ==================== 3. 模型一：构建 Next 数组 (Self-Matching) ====================
// 核心：模式串 p 自己和自己匹配。

void buildNext(string p) {
    int m = p.length(); 
    // 假设传入的 p 已经是 " " + p 的形式 (长度为实际长度+1)
    
    // i 从 2 开始，因为 ne[1] 肯定是 0
    // j 代表“当前已经匹配的前缀长度”
    for (int i = 2, j = 0; i < m; i++) {
        
        // 【核心中的核心】如果不匹配，j 不断回退
        // 这里的逻辑是：拿 p[i] (后缀新的一位) 和 p[j+1] (前缀下一位) 比！
        while (j > 0 && p[i] != p[j + 1]) {
            j = ne[j]; // 1-based 的回退非常干净，不用 -1
        }
        
        // 如果匹配成功，前缀长度 +1
        if (p[i] == p[j + 1]) {
            j++;
        }
        
        // 记录当前位置的 next 值
        ne[i] = j;
    }
}

// ==================== 4. 模型二：KMP 主匹配 (Pattern Matching) ====================
// 场景：在文本串 s 中找模式串 p 的所有出现位置。

void kmpSearch(string s, string p) {
    // 1. 强行转为 1-based
    s = " " + s;
    p = " " + p;
    
    int n = s.length(); // 实际遍历范围是 1 ~ n-1
    int m = p.length(); // 实际遍历范围是 1 ~ m-1
    
    // 2. 构建 Next 数组
    buildNext(p); 
    
    // 3. 开始匹配
    // i 扫描主串 s，从 1 开始 (不能跳过开头)
    // j 是模式串 p 当前匹配到的长度
    for (int i = 1, j = 0; i < n; i++) {
        
        // 如果不匹配，p 的指针 j 回退
        // 永远是用 s[i] (当前挑战者) 和 p[j+1] (下一关BOSS) 比！
        while (j > 0 && s[i] != p[j + 1]) {
            j = ne[j];
        }
        
        // 如果匹配，长度 +1
        if (s[i] == p[j + 1]) {
            j++;
        }
        
        // 4. 如果 j 达到了模式串长度 (注意这里 m 是加空格后的长度，所以有效长度是 m-1)
        if (j == m - 1) {
            // 输出起始位置
            cout << i - (m - 1) + 1 << endl;
            
            // 【关键】继续寻找下一个匹配
            // 假装最后一位失配，跳到下一个可能的重叠位置
            j = ne[j]; 
        }
    }
}

// ==================== 5. 模型三：最小循环节 ====================
// 场景：判断字符串 s 是否由某个子串重复多次构成。

int get_min_period(string s) {
    int n = s.length(); // 原始长度
    s = " " + s;        // 变为 1-based
    
    // 重新跑一遍 buildNext 得到 ne 数组 (略)
    
    // 最小循环单元长度 = 总长 - 最长公共前后缀
    int unit_len = n - ne[n];
    
    if (n % unit_len == 0) {
        return unit_len;
    } else {
        return n; 
    }
}

// ==================== 6. 进阶技巧一：递归跳 Next (求最短公共前后缀) ====================
// 场景：P3435 [POI2006] OKR-Periods of Words
// 目标：找到 i 的【最短非零公共前后缀】（即对应【最大周期】）。就是与上面模块五相反的问题。
// 原理：ne[i] 是最长 Border，ne[ne[i]] 是次长... 我们要找的是链条末端 >0 的那个值。

// 【加速原因】：
// 如果用 while(ne[j]>0) j=ne[j] 这种普通跳法，遇到 "aaaa...a" (全a) 这种数据，
// ne 链条会极长 (N -> N-1 -> ... -> 1)，导致每次查询都是 O(N)，总复杂度退化为 O(N^2) 超时。
// 【解决方案】：
// 使用类似“并查集”的路径压缩。一旦找到祖先，直接让 ne[i] 指向祖先。
// 下次再问 ne[i]，直接 O(1) 返回结果。

int find_shortest(int i) {
    // 1. 递归基：如果 ne[i] 为 0，说明 i 本身就是我们要找的“最小正非零值”
    //    (因为再往回跳就是 0 了，所以 i 就是链条的终点)
    if (ne[i] == 0) return i;
    
    // 2. 路径压缩 (Memoization)：
    //    递归去找 ne[i] 的终极祖先，并直接赋值给 ne[i]
    //    这样就把中间所有的节点都跳过了，链条被“压扁”了
    return ne[i] = find_shortest(ne[i]);
}

/* 
   实际使用示例 (以 P3435 为例):
   long long ans = 0;
   for (int i = 2; i <= n; i++) {
       int j = find_shortest(i); // 获取 i 的最短公共前后缀长度
       if (j != i) {             // 只要 j != i，说明存在循环节 (即 ne[i] > 0)
           ans += (i - j);       // 最大周期长度 = 总长 - 最短公共前后缀
       }
   }
*/


// ==================== 7. 进阶技巧二：KMP + 栈 (解决"删除/消除"类问题) ====================
// 场景：P4824。文本串 S 中，发现模式串 P 就立刻删掉，剩下的拼起来继续找。
//
// 核心思路：
//   普通KMP用单个变量j记录"当前匹配到模式串第几位"
//   但删除后j需要回退到之前某个值，单个变量无法保存历史
//   → 用f数组把每个时刻的j都存下来，f[k] = 栈里前k个字符末尾匹配到P的第几位
//   → 删除只是top指针后移，f数组原地不动，下一轮自动从f[top-1]恢复，无需额外处理
//普通KMP：
  //j 是单个变量，随着i前进更新

//KMP + 栈：
  //把每个时刻的 j 存进 f[]
  //"删除" = top后退（假删除）
  //"恢复" = f[top-1] 取历史j值
//
// 变量说明：
//   stk[k]  : 栈里第k个字符（当前还"存活"的文本串）
//   f[k]    : 栈里前k个字符，末尾匹配到模式串P的第几位（即该时刻的j值）
//   top     : 栈顶指针，手动维护（入栈++top，删除top-=m），与sizeof无关
//
// 时间复杂度：O(N)，和普通KMP一致

void kmp_with_stack(string s, string p) {
    int n = s.length(); s = " " + s;
    int m = p.length(); p = " " + p;
    buildNext(p);

    char stk[N]; // 模拟文本串的栈，存储当前存活的字符
    int f[N];    // f[k] = 栈里前k个字符末尾匹配到P的第几位（栈版本的j）
    int top = 0; // 栈顶指针，初始为空

    for (int i = 1; i <= n; i++) {
        stk[++top] = s[i];  // ① 入栈：当前字符进栈
        int j = f[top - 1]; // ② 恢复：从上一个栈顶取出历史j值
                            //    删除后top已后退，f[top-1]天然就是正确的历史状态

        while (j > 0 && s[i] != p[j + 1]) j = ne[j]; // KMP失配跳跃
        if (s[i] == p[j + 1]) j++;                    // 匹配成功前进

        f[top] = j; // ③ 记录：把当前j值存入f[top]，供后续恢复使用

        if (j == m) {   // ④ 消除：匹配到完整模式串
            top -= m;   //    弹出m个字符，top后退
                        //    无需手动处理j！下一轮f[top-1]自动取到正确值
        }
    }

    // 输出栈中剩余字符（即删除所有P后的结果）
    for (int i = 1; i <= top; i++) printf("%c", stk[i]);
}


// ==================== 9. 避坑指南 ====================
/*
1. 必须加空格！
   既然决定用 1-based，开头必须 s = " " + s。

2. 循环边界
   int n = s.length(); s = " " + s; 
   for(i=1; i<=n; i++) ... 
   这样写最稳。

3. 永远是 p[j+1]
   不要手滑写成 p[j]。
   口诀：j 是过去式（已匹配），j+1 是将来式（待匹配）。
*/
