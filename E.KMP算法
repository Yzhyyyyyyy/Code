// ==================================================================================
//                            KMP 算法 (Knuth-Morris-Pratt) 终极笔记
//                                  【1-based 竞赛通用版】
// ==================================================================================
// 核心哲学：永不回头 (Don't Look Back)。
// 核心变量：
//    s: 文本串 (主串)
//    p: 模式串 (子串)
//    ne[]: next 数组
//    i: 扫描指针 (永远往前走)
//    j: 匹配长度 (也是回退指针)

#include <bits/stdc++.h>
using namespace std;

const int N = 1000010;
int ne[N]; // next 数组，开在全局防止爆栈

// ==================== 0. 必读：0-based vs 1-based 的区别 ====================
/*
  这是新手最容易晕的地方，请死记以下区别：

  【0-based (C++原生)】              【1-based (竞赛推荐)】
  ----------------------------------------------------------------------
  字符串处理:  直接用 string s           加空格: s = " " + s;
  下标范围:    0 ~ len-1                1 ~ len
  比较逻辑:    s[i] == p[j]             s[i] == p[j+1]  <-- 核心区别！
  回退逻辑:    j = ne[j-1]              j = ne[j]       <-- 1-based 更干净
  Next含义:    ne[i]对应 p[0...i]       ne[i]对应 p[1...i]

  ★ 为什么推荐 1-based？
  1. 回退时不用写 j-1，直接 ne[j]，不容易越界。
  2. 比较时用 p[j+1]，逻辑是“拿当前位去匹配下一位”，非常符合思维直觉。
  3. 很多数学性质（如循环节）用 1-based 公式更简单。
*/

// ==================== 1. 核心定义：Next 数组 ====================
// 定义：ne[i] 表示模式串 p[1...i] 中，
//       【最长相等真前缀】和【最长相等真后缀】的长度。
// 举例：p = " ABABA" (注意前面有个空格)
//   i=1 ("A"):     ne[1] = 0
//   i=2 ("AB"):    ne[2] = 0
//   i=3 ("ABA"):   前缀"A", 后缀"A", ne[3] = 1
//   i=4 ("ABAB"):  前缀"AB", 后缀"AB", ne[4] = 2
//   i=5 ("ABABA"): 前缀"ABA", 后缀"ABA", ne[5] = 3

// ==================== 2. 模型一：构建 Next 数组 (Self-Matching) ====================
// 核心：模式串 p 自己和自己匹配。

void buildNext(string p) {
    int m = p.length(); 
    // 注意：这里的 m 已经是包含空格后的长度了，或者我们在主函数处理长度
    // 假设传入的 p 已经是 " " + p 的形式
    
    // i 从 2 开始，因为 ne[1] 肯定是 0
    // j 代表“当前已经匹配的前缀长度”
    for (int i = 2, j = 0; i < m; i++) {
        
        // 【核心中的核心】如果不匹配，j 不断回退
        // 这里的逻辑是：拿 p[i] 和 p[j+1] 比！
        // 也就是拿“后缀的末尾”和“前缀的下一位”比
        while (j > 0 && p[i] != p[j + 1]) {
            j = ne[j]; // 1-based 的回退非常干净，不用 -1
        }
        
        // 如果匹配成功，前缀长度 +1
        if (p[i] == p[j + 1]) {
            j++;
        }
        
        // 记录当前位置的 next 值
        ne[i] = j;
    }
}

// ==================== 3. 模型二：KMP 主匹配 (Pattern Matching) ====================
// 场景：在文本串 s 中找模式串 p 的所有出现位置。

void kmpSearch(string s, string p) {
    // 1. 强行转为 1-based
    s = " " + s;
    p = " " + p;
    
    int n = s.length(); // 实际遍历范围是 1 ~ n-1
    int m = p.length(); // 实际遍历范围是 1 ~ m-1
    
    // 2. 构建 Next 数组
    buildNext(p); // 注意 buildNext 里要适配这个长度逻辑
    
    // 3. 开始匹配
    // i 扫描主串 s，从 1 开始
    // j 是模式串 p 当前匹配到的长度
    for (int i = 1, j = 0; i < n; i++) {
        
        // 如果不匹配，p 的指针 j 回退
        // 永远是用 s[i] 和 p[j+1] 比！
        while (j > 0 && s[i] != p[j + 1]) {
            j = ne[j];
        }
        
        // 如果匹配，长度 +1
        if (s[i] == p[j + 1]) {
            j++;
        }
        
        // 4. 如果 j 达到了模式串长度 (注意这里 m 是加空格后的长度，所以有效长度是 m-1)
        if (j == m - 1) {
            // 输出起始位置
            cout << i - (m - 1) + 1 << endl;
            
            // 【关键】继续寻找下一个匹配
            // 假装最后一位失配，跳到下一个可能的重叠位置
            j = ne[j]; 
        }
    }
}

// ==================== 4. 模型三：最小循环节 (Minimum Cyclic Period) ====================
// 场景：判断字符串 s 是否由某个子串重复多次构成。
// 1-based 下的公式非常优美。

int get_min_period(string s) {
    int n = s.length(); // 原始长度
    s = " " + s;        // 变为 1-based
    
    // 重新跑一遍 buildNext 得到 ne 数组
    // ... (这里省略 buildNext 调用，假设 ne 已经算好了)
    
    // 最小循环单元长度 = 总长 - 最长公共前后缀
    int unit_len = n - ne[n];
    
    // 必须满足两个条件：
    // 1. ne[n] > 0 (说明有重复部分) -- 其实这个条件可以不强求，如果 ne[n]=0，unit_len=n，也能整除
    // 2. 总长度能被单元长度整除
    if (n % unit_len == 0) {
        return unit_len;
    } else {
        return n; // 没有循环节
    }
}

// ==================== 5. 避坑指南 (Blood & Tears) ====================
/*
1. 必须加空格！
   既然决定用 1-based，开头必须 s = " " + s。
   如果不加，下标 0 的位置会被忽略，全盘皆输。

2. 循环边界 i <= n 还是 i < n？
   如果你用了 s.length() 获取长度，记得 s.length() 是包含那个空格的。
   比如 s="abc"，加空格后 " abc"，length是4。
   遍历时 i 应该是 1, 2, 3。即 i < s.length()。
   或者你一开始 int n = s.length() (原始长度)，然后 i <= n。
   **推荐：** int n = s.length(); s = " " + s; for(i=1; i<=n; i++) ...

3. 永远是 p[j+1]
   不要手滑写成 p[j]。
   口诀：j 是过去式（已匹配），j+1 是将来式（待匹配）。
   拿现在的 i 去挑战将来的 j+1。

4. 输出 ne 数组时
   题目通常要求输出原始长度的 ne。
   记得循环是 for(int i=1; i<=原始长度; i++)。
*/

// ==================== 6. 完整 AC 代码模板 (洛谷 P3375) ====================
int main() {
    string s, p;
    cin >> s >> p;
    
    int n = s.length();
    int m = p.length();
    
    s = " " + s;
    p = " " + p;
    
    // 1. Build Next
    for (int i = 2, j = 0; i <= m; i++) {
        while (j > 0 && p[i] != p[j + 1]) j = ne[j];
        if (p[i] == p[j + 1]) j++;
        ne[i] = j;
    }
    
    // 2. KMP Search
    for (int i = 1, j = 0; i <= n; i++) {
        while (j > 0 && s[i] != p[j + 1]) j = ne[j];
        if (s[i] == p[j + 1]) j++;
        if (j == m) {
            cout << i - m + 1 << endl;
            j = ne[j];
        }
    }
    
    // 3. Print Next Array
    for (int i = 1; i <= m; i++) cout << ne[i] << " ";
    
    return 0;
}
