// ==================================================================================
//                            KMP 算法 (Knuth-Morris-Pratt) 终极笔记
// ==================================================================================
// 核心哲学：永不回头 (Don't Look Back)。
// 暴力匹配 (Brute Force) 的痛点是：一旦匹配失败，主串指针 i 要回退，模式串指针 j 要归零。
// KMP 的改进：
//   1. 主串指针 i 永远向前走，绝不回退。
//   2. 模式串指针 j 利用“已匹配信息”进行跳跃 (Jump)。
//   3. 核心在于预处理 Next 数组：告诉 j 匹配失败后该跳到哪。
// 复杂度：
//   时间：O(N + M) (线性，极其高效)。
//   空间：O(M) (只需要存模式串的 Next 数组)。

#include <bits/stdc++.h>
using namespace std;

// ==================== 1. 核心定义：Next 数组 (The Magic Array) ====================
// 定义：next[i] 表示模式串 P[0...i] 中，
//       【最长相等真前缀】和【最长相等真后缀】的长度。
// 举例：P = "ABABA"
//   i=0 ("A"):     前缀{}, 后缀{}, len=0
//   i=1 ("AB"):    前缀{A}, 后缀{B}, len=0
//   i=2 ("ABA"):   前缀{A, AB}, 后缀{A, BA}, 公共{A}, len=1
//   i=3 ("ABAB"):  前缀{A, AB, ABA}, 后缀{B, AB, BAB}, 公共{AB}, len=2
//   i=4 ("ABABA"): 公共{ABA}, len=3
// 作用：当 P[i+1] 匹配失败时，我们可以直接跳到 next[i] 的位置继续比，
//       因为那一段前缀和后缀是一样的，不用重比。

// ==================== 2. 模型一：构建 Next 数组 (Self-Matching) ====================
// 核心：模式串 P 自己和自己匹配。
// 这里的写法采用 C++ 标准的 0-based (下标从 0 开始)。

vector<int> buildNext(const string& p) {
    int m = p.length();
    vector<int> nxt(m, 0); // 初始化全 0
    
    // j 代表“当前已经匹配的前缀长度”
    // i 代表“当前正在处理的后缀末尾位置”
    // i 从 1 开始，因为 nxt[0] 必然是 0
    for (int i = 1, j = 0; i < m; i++) {
        
        // 【核心中的核心】如果不匹配，j 不断回退 (Jump)
        // 只要 j > 0 且当前字符不一样，就找“上一个可能的最长前缀”
        // 为什么是 nxt[j-1]？因为 j 是长度，j-1 是下标。
        while (j > 0 && p[i] != p[j]) {
            j = nxt[j - 1];
        }
        
        // 如果匹配成功，前缀长度 +1
        if (p[i] == p[j]) {
            j++;
        }
        
        // 记录当前位置的 next 值
        nxt[i] = j;
    }
    return nxt;
}

// ==================== 3. 模型二：KMP 主匹配 (Pattern Matching) ====================
// 场景：在文本串 S 中找模式串 P 的所有出现位置。
// 逻辑：和 buildNext 惊人地相似！只不过是 S 和 P 比。

vector<int> kmpSearch(const string& s, const string& p) {
    vector<int> positions;
    if (p.empty()) return positions;
    
    // 1. 预处理模式串的 Next 数组
    vector<int> nxt = buildNext(p);
    
    int n = s.length();
    int m = p.length();
    
    // j 是模式串 P 当前匹配到的长度 (也是 P 下一个待比字符的下标)
    for (int i = 0, j = 0; i < n; i++) { // i 扫描主串 S
        
        // 2.如果不匹配，P 的指针 j 回退
        // 这里的逻辑和 buildNext 一模一样
        while (j > 0 && s[i] != p[j]) {
            j = nxt[j - 1];
        }
        
        // 3. 如果匹配，长度 +1
        if (s[i] == p[j]) {
            j++;
        }
        
        // 4. 如果 j 达到了模式串长度，说明完全匹配了！
        if (j == m) {
            // 记录起始位置 (i 是末尾，长度是 m，所以起始是 i - m + 1)
            positions.push_back(i - m + 1);
            
            // 【关键】继续寻找下一个匹配
            // 匹配成功后，假装最后一位“失配”了，利用 next 数组跳到下一个可能的重叠位置
            j = nxt[j - 1]; 
        }
    }
    return positions;
}

// ==================== 4. 模型三：最小循环节 (Minimum Cyclic Period) ====================
// 场景：判断字符串 S 是否由某个子串重复多次构成。
// 定理：对于长度为 len 的字符串 S，
//       如果 len % (len - next[len-1]) == 0，
//       那么最小循环节长度就是 L = len - next[len-1]。
//       否则，最小循环节就是 S 本身。

int get_min_period(const string& s) {
    int n = s.length();
    vector<int> nxt = buildNext(s);
    
    // len - next[n-1] 是“最小循环单元”的长度候选
    int unit_len = n - nxt[n - 1];
    
    // 必须满足两个条件：
    // 1. next[n-1] > 0 (说明有公共前后缀，即有重复部分)
    // 2. 总长度能被单元长度整除
    if (nxt[n - 1] > 0 && n % unit_len == 0) {
        return unit_len;
    } else {
        return n; // 没有循环节，周期就是它自己
    }
}

// ==================== 5. 避坑指南 (Blood & Tears) ====================
/*
1. 下标体系 (0-based vs 1-based)
   痛点：算法导论和很多老模板用 1-based (字符串下标从1开始)。
        但 C++ string 是 0-based。
   建议：死记上面这套 0-based 模板。
        如果是 1-based，代码里的 nxt[j-1] 会变成 nxt[j]，容易搞混。

2. While 循环 (Continuous Fallback)
   错误：把 while 写成了 if。
   后果：如果退一步还是不匹配，程序就停止回退直接往下走了，导致漏解。
   修正：必须用 while，直到匹配成功或者退无可退 (j=0)。

3. 这里的 Next 数组定义
   注意：有些教材的 next[i] 存的是“匹配失败后 j 要跳到的位置”，
        这通常把上面的 next 数组整体右移一位，且 next[0] = -1。
   区分：我们这里 next[i] 存的是“最长公共前后缀长度”。
        这是最直观、最好记的定义。实际使用时用 nxt[j-1] 查表即可。

4. 循环节公式的坑
   错误：直接认为 period = n - next[n-1]。
   修正：必须检查整除条件 (n % period == 0)。
        比如 "abcab"，next=2，n-next=3，但 "abc" 不是循环节。

5. 空串处理
   错误：不判空直接跑 buildNext。
   修正：if (p.empty()) return ...; 否则 vector 初始化可能出问题。
*/
