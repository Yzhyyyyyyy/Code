// ==================================================================================
//                        数位 DP (Digit DP) 核心笔记
// ==================================================================================
// 核心哲学：不要一个一个枚举，按"位"来统计，用 DP 记录已有的约束状态。
// 如果题目是 "统计 [1, N] 中满足条件的数有多少"，那就拆位做 DP。

// ==================== 0. 🚨 你的"旧伤"警示录 (必读) ====================
// 在你之前的 Windy 数代码中，这三个地方导致了逻辑崩盘，请死死记住：

// 1. tight (限制) 的真正含义 —— 别再用下标比数值了！
//    - 你的误区：你写了 if (i != position)。position 是"第几位"，i 是"填的数字"。
//      拿"下标"去和"数值"比较，逻辑是完全错误的！
//    - 正确逻辑：tight 只看 **当前填的数字 i** 是否贴着 **原数字 N 对应位的数值 digits[pos]**。

// 2. 记忆化的条件 —— 别什么都存！
//    - 你的误区：dp 数组开了 20 亿；或者不管 tight 是啥都存进 dp。
//    - 正确逻辑：只有 **!tight (无限制)** 且 **!lead (非前导零)** 时，状态才是通用的，才能存/读 dp。

// 3. 递归的尽头 —— 别忘了回家！
//    - 你的误区：忘了写 if (pos < 0)，导致无限递归或越界。
//    - 正确逻辑：pos < 0 代表数字填完了，这是一个合法的方案，必须 return 1;

// ==================== 1. 核心定义与适用场景 ====================
// 适用范围：
//   1. 统计 [L, R] 中满足某种数字条件的整数个数。
//   2. 条件与数字的"每一位"有关（如：不含某个数字、相邻位不同、数字和为某值）。
//   3. 数据范围很大（N 可达 10^18），暴力枚举不可行。

// 核心思想：
//   - 暴力：枚举 1 ~ N 的每个数，逐一判断。-> O(N) 必超时
//   - 数位 DP：把数字按位拆开，从高位到低位逐位填，
//              用 DP 记录"当前填到第几位、有哪些约束"。-> O(位数 * 状态数)

// 核心技巧：前缀转化
//   [L, R] 的答案 = f(R) - f(L-1)
//   只需要写一个 f(N) = 统计 [0, N] 中满足条件的数的个数。

// ==================== 2. 通用模板 ====================

// -------------------- 状态设计 --------------------
// dp[pos][state]
//   pos     : 当前填到第几位（从高位到低位）
//   state   : 题目要求的核心状态（如数字和、上一位的值等）
//   注意：tight 和 lead 通常作为 dfs 参数，不记录在 dp 数组维度里（除非很特殊）

// ==================== 3. 经典例题：Windy 数 (P2657) ====================
// 题意：统计 [L, R] 中，相邻两位之差的绝对值 >= 2 的整数个数。
// 状态：上一位填了什么数字 (last)

#include <bits/stdc++.h>
using namespace std;

int digits[15];      // 存储 N 的每一位
int dp[15][15];      // dp[pos][last]：当前在第 pos 位，上一位填的是 last

// pos:   当前处理第几位 (从高到低)
// last:  上一位填的数字 (用于和当前位比较差值)
// tight: 是否受到上界限制 (true=只能填到 digits[pos], false=0~9随便填)
// lead:  是否处于前导零状态 (true=还在填前导零, false=已经开始填有效数字)
int dfs_windy(int pos, int last, bool tight, bool lead) {
    // 1. 终止条件：填完所有位，说明找到一个合法数，返回 1
    if (pos < 0) return 1;

    // 2. 记忆化读取
    // 只有在 "没有限制" 且 "不是前导零" 的情况下才能复用结果
    if (!tight && !lead && last != -1 && dp[pos][last] != -1) {
        return dp[pos][last];
    }

    // 3. 确定当前位的枚举范围
    int limit = tight ? digits[pos] : 9;
    int res = 0;

    for (int i = 0; i <= limit; i++) {
        // 4. 判断是否合法 (Windy 数定义)
        if (!lead && abs(i - last) < 2) continue;

        // 5. 状态转移
        bool new_lead = lead && (i == 0);
        bool new_tight = tight && (i == limit);
        int new_last = new_lead ? -1 : i;

        res += dfs_windy(pos - 1, new_last, new_tight, new_lead);
    }

    // 6. 记忆化存储
    if (!tight && !lead && last != -1) {
        dp[pos][last] = res;
    }

    return res;
}

int solve_windy(int x) {
    int len = 0;
    while (x) {
        digits[len++] = x % 10;
        x /= 10;
    }
    memset(dp, -1, sizeof(dp));
    return dfs_windy(len - 1, -1, true, true);
}


// ==================== 4. 经典例题：数字计数 (P2602) ====================
// 题意：统计 [L, R] 中，数字 0~9 各出现了多少次。

// ------------------------------------------------------------------
// 🚨【你的错误纠察队】(针对你刚才提交的代码)
// 1. 绝对禁止在循环里写 continue：
//    - 错误：if (i != target) continue;
//    - 后果：你把不含 target 的数字全扔了！但那些数字也存在啊！
//    - 修正：不管 i 是几都要递归，只是 cnt 不加而已。
//
// 2. 返回值大不同：
//    - Windy数：问"有多少个数"，返回 1。
//    - 数字计数：问"出现了几次"，返回 cnt (累计值)。
//
// 3. DP 状态必须包含变化的量：
//    - 错误：dp[pos][target] (忽略了 cnt)
//    - 后果：cnt=1 和 cnt=5 的情况混在一起了。
//    - 修正：dp[pos][cnt]
// ------------------------------------------------------------------

long long memo_count[15][15]; // dp[pos][cnt]
int a[15];                    // 存储数字 N
int target;                   // 当前正在统计哪个数字

// pos:   当前位
// cnt:   之前位中，target 已经出现了几次
// tight: 限制
// lead:  前导零
long long dfs_count(int pos, int cnt, bool tight, bool lead) {
    // 1. 递归终点：填完了
    // 返回 cnt，意味着：这一条路径产生了一个合法的数，
    // 这个数里 target 出现了 cnt 次，所以对总答案贡献 cnt。
    if (pos < 0) return cnt;

    // 2. 记忆化
    // 只有无限制且非前导零时，dp[pos][cnt] 才是通用的
    if (!tight && !lead && memo_count[pos][cnt] != -1)
        return memo_count[pos][cnt];

    int limit = tight ? a[pos] : 9;
    long long res = 0;

    for (int i = 0; i <= limit; i++) {
        // 3. 计算新的 cnt
        // 关键逻辑：
        // 如果当前位填的数字 i 等于 target，cnt 要 +1。
        // 但是！如果处于前导零状态 (lead=true) 且填的是 0 (i=0)，
        // 这个 0 是无效的占位符，不能算作 target 出现了一次。
        
        int new_cnt = cnt;
        if (i == target) {
            // 如果不是前导零状态，或者填的不是0 (即非前导零的有效数字)
            if (!lead || i != 0) { 
                new_cnt++;
            }
        }

        // 4. 状态更新
        bool new_lead = lead && (i == 0);
        bool new_tight = tight && (i == limit);

        res += dfs_count(pos - 1, new_cnt, new_tight, new_lead);
    }

    // 5. 记录
    if (!tight && !lead) memo_count[pos][cnt] = res;
    return res;
}

long long solve_count(long long x, int d) {
    int len = 0;
    while (x) {
        a[len++] = x % 10;
        x /= 10;
    }
    target = d;
    memset(memo_count, -1, sizeof(memo_count));
    // 从最高位开始，初始 cnt=0
    return dfs_count(len - 1, 0, true, true);
}

