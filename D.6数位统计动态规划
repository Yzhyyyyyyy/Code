// ==================================================================================
//                        数位 DP (Digit DP) 核心笔记
// ==================================================================================
// 核心哲学：不要一个一个枚举，按"位"来统计，用 DP 记录已有的约束状态。
// 如果题目是 "统计 [1, N] 中满足条件的数有多少"，那就拆位做 DP。

// ==================== 0. 🚨 你的"旧伤"警示录 (必读) ====================
// 在你之前的 Windy 数代码中，这三个地方导致了逻辑崩盘，请死死记住：

// 1. tight (限制) 的真正含义 —— 别再用下标比数值了！
//    - 你的误区：你写了 if (i != position)。position 是"第几位"，i 是"填的数字"。
//      拿"下标"去和"数值"比较，逻辑是完全错误的！
//    - 正确逻辑：tight 只看 **当前填的数字 i** 是否贴着 **原数字 N 对应位的数值 digits[pos]**。
//      如果原数字是 356，当前填百位：
//      填 0~2 (比3小) -> 解除限制 (tight=false)
//      填 3   (等于3) -> 保持限制 (tight=true)
//      填 4+  (比3大) -> 不允许

// 2. 记忆化的条件 —— 别什么都存！
//    - 你的误区：dp 数组开了 20 亿；或者不管 tight 是啥都存进 dp。
//    - 正确逻辑：只有 **!tight (无限制)** 且 **!lead (非前导零)** 时，状态才是通用的，才能存/读 dp。
//      如果 tight=true，说明这一位的上限取决于原数字 N，不能复用给别的数字。

// 3. 递归的尽头 —— 别忘了回家！
//    - 你的误区：忘了写 if (pos < 0)，导致无限递归或越界。
//    - 正确逻辑：pos < 0 代表数字填完了，这是一个合法的方案，必须 return 1;

// ==================== 1. 核心定义与适用场景 ====================
// 适用范围：
//   1. 统计 [L, R] 中满足某种数字条件的整数个数。
//   2. 条件与数字的"每一位"有关（如：不含某个数字、相邻位不同、数字和为某值）。
//   3. 数据范围很大（N 可达 10^18），暴力枚举不可行。

// 核心思想：
//   - 暴力：枚举 1 ~ N 的每个数，逐一判断。-> O(N) 必超时
//   - 数位 DP：把数字按位拆开，从高位到低位逐位填，
//              用 DP 记录"当前填到第几位、有哪些约束"。-> O(位数 * 状态数)

// 核心技巧：前缀转化
//   [L, R] 的答案 = f(R) - f(L-1)
//   只需要写一个 f(N) = 统计 [0, N] 中满足条件的数的个数。

// ==================== 2. 通用模板 ====================

// -------------------- 状态设计 --------------------
// dp[pos][state]
//   pos     : 当前填到第几位（从高位到低位）
//   state   : 题目要求的核心状态（如数字和、上一位的值等）
//   注意：tight 和 lead 通常作为 dfs 参数，不记录在 dp 数组维度里（除非很特殊）

// ==================== 3. 经典例题：Windy 数 (P2657) ====================
// 题意：统计 [L, R] 中，相邻两位之差的绝对值 >= 2 的整数个数。
// 状态：上一位填了什么数字 (last)

#include <bits/stdc++.h>
using namespace std;

int digits[15];      // 存储 N 的每一位
int dp[15][15];      // dp[pos][last]：当前在第 pos 位，上一位填的是 last

// pos:   当前处理第几位 (从高到低)
// last:  上一位填的数字 (用于和当前位比较差值)
// tight: 是否受到上界限制 (true=只能填到 digits[pos], false=0~9随便填)
// lead:  是否处于前导零状态 (true=还在填前导零, false=已经开始填有效数字)
int dfs_windy(int pos, int last, bool tight, bool lead) {
    // 1. 终止条件：填完所有位，说明找到一个合法数，返回 1
    if (pos < 0) return 1;

    // 2. 记忆化读取
    // 只有在 "没有限制" 且 "不是前导零" 的情况下才能复用结果
    // (tight=true 时结果依赖于原数字 N，不能复用)
    if (!tight && !lead && last != -1 && dp[pos][last] != -1) {
        return dp[pos][last];
    }

    // 3. 确定当前位的枚举范围
    // 如果 tight 为 true，只能填到 digits[pos]；否则可以填到 9
    int limit = tight ? digits[pos] : 9;
    int res = 0;

    for (int i = 0; i <= limit; i++) {
        // 4. 判断是否合法 (Windy 数定义)
        // 只有当 "不是前导零" 时，才需要检查 abs(i - last) >= 2
        // 如果 lead=true (还在前导零)，填什么都行(通常是0)，或者第一位有效数字填什么都行
        if (!lead && abs(i - last) < 2) continue;

        // 5. 状态转移
        // new_lead: 如果当前是前导零且填了0，则继续是前导零
        // new_tight: 当前受限 且 填到了上限，下一位才受限
        bool new_lead = lead && (i == 0);
        bool new_tight = tight && (i == limit);
        
        // new_last: 如果是前导零状态，传 -1 (或者随便传，反正下一层会看 lead)；否则传 i
        int new_last = new_lead ? -1 : i;

        res += dfs_windy(pos - 1, new_last, new_tight, new_lead);
    }

    // 6. 记忆化存储
    // 同样，只有无限制且非前导零时才存
    if (!tight && !lead && last != -1) {
        dp[pos][last] = res;
    }

    return res;
}

int solve(int x) {
    int len = 0;
    while (x) {
        digits[len++] = x % 10;
        x /= 10;
    }
    // 初始化 memo 为 -1
    memset(dp, -1, sizeof(dp));
    
    // 从最高位开始搜，初始 tight=true, lead=true, last=-1
    return dfs_windy(len - 1, -1, true, true);
}

// 主函数调用示例： cout << solve(b) - solve(a - 1) << endl;


// ==================== 4. 经典例题：数字计数 (P2602) ====================
// 题意：统计 [L, R] 中，数字 0~9 各出现了多少次。
// 状态：当前统计的目标数字 x，以及已经出现了多少次

// 对每个数字 x 分别跑一次数位 DP
// state = 数字 x 出现的次数

long long memo_count[13][13]; // memo[pos][cnt]

long long dfs_count(int pos, int cnt, int x, bool tight, bool started) {
    if (pos < 0) return cnt; // 返回出现次数，不是返回 0/1

    if (!tight && started && memo_count[pos][cnt] != -1)
        return memo_count[pos][cnt];

    int limit = tight ? digits[pos] : 9;
    long long res = 0;

    for (int d = 0; d <= limit; d++) {
        int new_cnt = cnt;
        if (started || d != 0) { // 排除前导零
            if (d == x) new_cnt++;
        }
        res += dfs_count(pos - 1, new_cnt, x, tight && (d == limit), started || d != 0);
    }

    if (!tight && started) memo_count[pos][cnt] = res;
    return res;
}

// ==================== 5. 避坑指南 (Blood & Tears) ====================
/*
   1. tight=true 时绝对不能记忆化！
      - 因为 tight=true 时，当前位的上界是 digits[pos]，不同数字 N 会不同。
      - 只有 tight=false 时，状态才是"自由的"，可以复用。

   2. 前导零的处理：
      - started=false (即 lead=true) 表示还没填过非零位，这时候填 0 不算"真正的 0"。
      - 比如数字 007，前两个 0 是前导零，不算在数字里。
      - 很多状态在 started=false 时要特殊处理（如 last_digit 不能约束第一位）。

   3. digits 数组的方向：
      - 建议存成 digits[0] = 最低位，digits[len-1] = 最高位。
      - dfs 从 pos=len-1 开始往下填，pos=0 时填最低位。
      - 方向搞反了，结果就全错了。

   4. 答案类型：
      - 统计"个数"时返回 int/long long。
      - 统计"出现次数之和"时返回 long long（N 可达 10^18，次数也很大）。

   5. f(L-1) 的边界：
      - 当 L=0 时，f(L-1) = f(-1)，要特判返回 0。
      - 或者直接让 f(0) = 0（0 本身通常不满足条件）。
*/
