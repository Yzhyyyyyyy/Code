// ==================== 3. 模型一：基础棋盘类 (单行依赖) ====================
// 经典例题：P1879 [USACO06NOV] Corn Fields (种草)
// 场景：N*M 的网格，某些格子不能放，放了东西不能相邻。
// 状态：dp[i][state] -> 第 i 行状态为 state 时的方案数/最大值。
// 转移：只看上一行 (i-1)。

#include <vector>
#include <iostream>
#include <algorithm>
#include <cstring>
using namespace std;

const int MOD = 100000000;
int n, m;
int dp_corn[13][1 << 12]; // 不用滚动数组也可以，N很小
int map_limit[13];        // 地形限制 (1表示土地肥沃，0表示贫瘠，需根据题目转换)
vector<int> legal_states; // 预处理出所有单行合法的状态

void solve_corn_fields() {
    // 1. 预处理单行合法状态 (行内不相邻)
    for (int i = 0; i < (1 << m); i++) {
        if ((i & (i << 1)) == 0) legal_states.push_back(i);
    }

    // 2. 初始化第一行
    for (int state : legal_states) {
        if ((state & map_limit[1]) == state) // 确保种在肥沃土地上
            dp_corn[1][state] = 1;
    }

    // 3. 逐行递推
    for (int i = 2; i <= n; i++) {
        for (int curr : legal_states) { // 枚举当前行
            if ((curr & map_limit[i]) != curr) continue; // 地形检查

            for (int prev : legal_states) { // 枚举上一行
                // 行间冲突检查 (上下不相邻)
                if ((curr & prev) == 0) {
                    dp_corn[i][curr] = (dp_corn[i][curr] + dp_corn[i-1][prev]) % MOD;
                }
            }
        }
    }
}

// ==================== 4. 模型二：棋盘 + 背包 (数量限制) ====================
// 经典例题：P1896 [SCOI2005] 互不侵犯 (King)
// 场景：在 N*N 中放 K 个国王，互不攻击。
// 特点：不仅要状态合法，还要正好用完 K 个棋子。
// 状态：dp[i][state][count] -> 第 i 行，状态 state，前 i 行共用了 count 个棋子。
// 本质：状压 DP + 分组背包。

long long dp_king[10][1 << 9][85]; 
int cnt[1 << 9]; // 预处理每个状态包含的棋子数

void solve_kings() {
    int K; // 总棋子数
    // ... 预处理 legal_states 和 cnt ...

    // 初始化第一行
    for (int s : legal_states) 
        if (cnt[s] <= K) dp_king[1][s][cnt[s]] = 1;

    for (int i = 2; i <= n; i++) {
        for (int curr : legal_states) {
            for (int prev : legal_states) {
                // 检查冲突：垂直、左下、右下
                if ((curr & prev) == 0 && 
                    (curr & (prev << 1)) == 0 && 
                    (curr & (prev >> 1)) == 0) {
                    
                    // 背包转移：枚举之前已用的总数 j
                    // 当前行用了 cnt[curr]，所以之前最多用 K - cnt[curr]
                    for (int j = 0; j <= K - cnt[curr]; j++) {
                        dp_king[i][curr][j + cnt[curr]] += dp_king[i-1][prev][j];
                    }
                }
            }
        }
    }
    // 统计 dp[n][state][K] 的和
}

// ==================== 5. 模型三：多行依赖 (滚动数组) ====================
// 经典例题：P2704 [NOI2001] 炮兵阵地
// 难点：攻击范围 2 格，受 i-1 和 i-2 影响。
// 状态：dp[滚动][当前行][上一行] -> 三维数组。

int dp_cannon[2][1024][1024]; // 滚动数组优化空间

void solve_cannon() {
    // 预处理略...
    for (int i = 0; i < n; i++) {
        int now = i % 2;
        int pre = 1 - now;
        // ⚠️ 必须清空当前层，因为是 max 转移
        memset(dp_cannon[now], -1, sizeof(dp_cannon[now])); 

        for (int curr : legal_states) {
            // ... 地形检查 ...
            // 若 i >= 2:
            for (int last : legal_states) { // 上一行
                if (curr & last) continue; // 剪枝
                
                for (int last2 : legal_states) { // 上上行
                    // 核心冲突检查：三行之间两两不能冲突
                    if (!(curr & last) && !(curr & last2) && !(last & last2)) {
                        // 转移
                        dp_cannon[now][curr][last] = max(dp_cannon[now][curr][last], 
                                                         dp_cannon[pre][last][last2] + cnt[curr]);
                    }
                }
            }
        }
    }
}

// ==================== 6. 模型四：集合/路径类 (TSP问题) ====================
// 经典例题：P1433 吃奶酪 / P4925 / TSP
// 场景：旅行商问题、经过所有点的最短路径。
// 状态：dp[mask][u] -> mask 表示已经走过的点集(二进制)，u 表示当前停留在节点 u。
// 区别：这里不分“行”，而是分“集合大小”或“最后到达的点”。

const int MAX_TSP = 20;
double dp_tsp[1 << MAX_TSP][MAX_TSP];
double dist[MAX_TSP][MAX_TSP]; // 距离矩阵

void solve_tsp() {
    // 初始化为无穷大
    // memset(dp_tsp, 127, sizeof(dp_tsp));

    // 假设从 0 点出发 (视题目而定，有时是任意点出发)
    dp_tsp[1][0] = 0; 

    // 1. 枚举状态 mask (从小到大，确保子状态先被计算)
    for (int mask = 1; mask < (1 << n); mask++) { 
        // 2. 枚举当前所在的点 u (u 必须在 mask 里)
        for (int u = 0; u < n; u++) { 
            if (!((mask >> u) & 1)) continue; 
            
            // 3. 枚举上一个点 v (v 必须在 mask 移除 u 后的集合里)
            int prev_mask = mask ^ (1 << u);
            if (prev_mask == 0) continue; 

            for (int v = 0; v < n; v++) { 
                if ((prev_mask >> v) & 1) {
                    // 转移方程：从 v 走到 u
                    dp_tsp[mask][u] = min(dp_tsp[mask][u], dp_tsp[prev_mask][v] + dist[v][u]);
                }
            }
        }
    }
}

// ==================== 7. 避坑指南 (Blood & Tears) ====================
/*
   1. 优先级灾难：
      错误：if (i & i << 1 == 0)  -> == 优先级高于 &
      正确：if ((i & (i << 1)) == 0)

   2. 数组越界：
      - 这里的数组通常很大 (1<<20)，小心 MLE。
      - 涉及减法下标 (如 k - cnt[j]) 时，务必检查是否 < 0。

   3. 初始化问题：
      - 求最大值：memset -1 或 0。
      - 求最小值：memset 0x3f (无穷大)。
      - 滚动数组每次使用前要 memset 清空当前层。

   4. 循环顺序：
      - 棋盘类：外层循环是 行 (Row)。
      - 集合类：外层循环是 状态 (Mask)。
*/
