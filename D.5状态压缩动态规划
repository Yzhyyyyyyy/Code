// ==================== 3. 基础模型：棋盘类/单行依赖 ====================
// 经典例题：P1879 [USACO06NOV] Corn Fields (种草)
// 场景：N*M 的网格，某些格子不能放，放了东西不能相邻。
// 策略：一行一行处理，当前行的状态只受上一行限制。

#include <vector>
#include <iostream>
#include <algorithm>
#include <cstring>
using namespace std;

const int MOD = 100000000;
int n, m;
int dp[2][1 << 12];    // 滚动数组优化
int locate[14];        // 地形限制 (1表示不能种)
vector<int> available; // 预处理出所有单行合法的状态

// 辅助函数：计算1的个数（如果是求最大种植数用这个，求方案数则不需要）
int countOne(int x) {
    int res = 0;
    while(x) { res++; x &= (x - 1); }
    return res;
}

void solve_corn_fields() {
    // 1. 预处理所有可能的单行合法状态
    for (int i = 0; i < (1 << m); i++) {
        // 【注意】位运算优先级：((i & (i << 1)) == 0)
        if ((i & (i << 1)) == 0) {
            available.push_back(i);
        }
    }

    // 2. 逐行递推
    for (int i = 0; i < n; i++) {
        int now = i % 2;
        int pre = 1 - now;
        
        // 【关键】清空当前行画布
        memset(dp[now], 0, sizeof(dp[now]));

        for (int tem : available) { // 枚举当前行
            // 地形冲突检查：如果 tem 种在了贫瘠土地(locate[i])上
            if ((tem & locate[i]) != 0) continue;

            if (i == 0) {
                dp[now][tem] = 1; // 方案数初始化为1 (如果是求最大数则 = countOne(tem))
            } 
            else {
                for (int j : available) { // 枚举上一行
                    // 检查：当前行 vs 上一行 (上下不相邻)
                    if ((tem & j) == 0) {
                        dp[now][tem] = (dp[now][tem] + dp[pre][j]) % MOD;
                    }
                }
            }
        }
    }
    // 3. 统计最后一行所有状态的和
}

// ==================== 4. 进阶模型：多行依赖 (炮兵阵地) ====================
// 经典例题：P2704 [NOI2001] 炮兵阵地
// 难点：炮兵攻击范围是 2 格。当前行不仅受 i-1 行影响，还受 i-2 行影响。
// 解决：状态需要增加一维，记录上一行的状态。
// 定义：dp[滚动][当前行状态][上一行状态]

/* 
   ⚠️⚠️⚠️【血泪坑点总结 - 考试前必看】⚠️⚠️⚠️
   1. 优先级灾难：if ((i & (i << 1)) == 0) -> 必须加括号！
   2. Memset 自杀：memset(dp[now], -1, ...) -> 必须清空 now，绝不能清空 pre！
   3. 冲突检查漏项：必须检查 (tem&j), (tem&k), (j&k) 三者！缺一不可！
*/

int dp_cannon[2][1024][1024]; // dp[滚动][当前][上]
// locate 和 available 复用上面的定义

void solve_cannon() {
    // ... 输入 locate 和预处理 available (同上) ...
    // available 预处理条件：((i & (i << 1)) == 0) && ((i & (i << 2)) == 0)

    for (int i = 0; i < n; i++) {
        int now = i % 2;
        int pre = 1 - now;
        
        // 【坑点2】初始化为 -1，表示状态不可达
        memset(dp_cannon[now], -1, sizeof(dp_cannon[now]));

        for (int tem : available) {
            if ((tem & locate[i]) != 0) continue; // 地形冲突

            // --- 情况 A: 第一行 (i=0) ---
            if (i == 0) {
                dp_cannon[now][tem][0] = countOne(tem);
            }
            // --- 情况 B: 第二行 (i=1) ---
            else if (i == 1) {
                for (int j : available) { // 枚举上一行
                    if ((tem & j) == 0) { // 检查当前 vs 上一
                        if (dp_cannon[pre][j][0] != -1)
                            dp_cannon[now][tem][j] = max(dp_cannon[now][tem][j], dp_cannon[pre][j][0] + countOne(tem));
                    }
                }
            }
            // --- 情况 C: 第三行及以后 (i>=2) ---
            else {
                for (int j : available) { // 枚举上一行
                    // 【提速技巧】先检查 tem 和 j，冲突直接 continue
                    if ((tem & j) != 0) continue; 

                    for (int k : available) { // 枚举上上行
                        // 【坑点3】必须检查三者冲突，尤其是 j & k (保证历史清白)
                        if (((tem & k) == 0) && ((j & k) == 0)) {
                            if (dp_cannon[pre][j][k] != -1)
                                dp_cannon[now][tem][j] = max(dp_cannon[now][tem][j], dp_cannon[pre][j][k] + countOne(tem));
                        }
                    }
                }
            }
        }
    }
    // 统计答案：遍历 dp[(n-1)%2][i][j] 取 max
}

// ==================== 5. 集合类/连通性状压 (TSP问题) ====================
// 经典例题：P1896 互不侵犯 (其实是棋盘类)，但此处指 P4925 或 TSP 类问题
// 场景：吃奶酪、旅行商问题、经过所有点的最短路径。
// 状态：dp[mask][u] -> mask 表示已经走过的点集(二进制)，u 表示当前停留在节点 u。

const int MAX_TSP = 20;
int dp_tsp[1 << MAX_TSP][MAX_TSP];
int dist[MAX_TSP][MAX_TSP]; // 距离矩阵

void solve_tsp() {
// 初始化为无穷大
// memset(dp_tsp, 0x3f, sizeof(dp_tsp));


// 假设从 0 点出发，状态为 00...01
dp_tsp[1][0] = 0; 

// 1. 枚举状态 (从小到大，确保子状态先被计算)
for (int state = 1; state < (1 << n); state++) { 
    // 2. 枚举当前所在的点 u
    for (int u = 0; u < n; u++) { 
        if (!((state >> u) & 1)) continue; // 状态里必须包含 u
        
        int prev_state = state ^ (1 << u); // 移除 u 得到上一个状态
        if (prev_state == 0) continue; 
        
        // 3. 枚举上一个点 v
        for (int v = 0; v < n; v++) { 
            if ((prev_state >> v) & 1) {
                dp_tsp[state][u] = min(dp_tsp[state][u], dp_tsp[prev_state][v] + dist[v][u]);
            }
        }
    }
}
}

