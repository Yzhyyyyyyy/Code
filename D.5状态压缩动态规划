// ======================================================================================
// 模块一：位运算速查表 (Bitwise Cheat Sheet)
// ======================================================================================
// 熟练掌握这些操作是做状压 DP 的前提

namespace BitUtils {
    // 1. 检查第 i 位是否为 1 (从 0 开始计数)
    inline bool is_set(int state, int i) { return (state >> i) & 1; }

    // 2. 将第 i 位置为 1
    inline int set_bit(int state, int i) { return state | (1 << i); }

    // 3. 将第 i 位置为 0
    inline int clear_bit(int state, int i) { return state & ~(1 << i); }

    // 4. 将第 i 位取反
    inline int toggle_bit(int state, int i) { return state ^ (1 << i); }

    // 5. 取出最低位的 1 (Lowbit)
    inline int lowbit(int x) { return x & -x; }

    // 6. 检查是否有相邻的 1 (用于棋盘类，如互不侵犯、种草)
    // 返回 true 表示有相邻 1 (非法)
    inline bool has_adjacent_ones(int state) { return (state & (state << 1)) != 0; }

    // 7. 统计二进制中 1 的个数 (__builtin_popcount 是 GCC 内置函数)
    inline int count_ones(int state) { return __builtin_popcount(state); }

    // 8. 枚举子集 (Subsets) - 高级技巧
