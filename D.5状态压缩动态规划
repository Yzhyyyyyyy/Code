// ======================================================================================
// 模块二：基础棋盘模型 - 单行依赖
// 典型例题：P1879 [USACO06NOV] Corn Fields (种草)
// 题目概要：N*M 网格，有些土地贫瘠(0)不能种，种草不能相邻。求方案数。
// ======================================================================================

namespace CornFields {
    const int MAXN = 14;
    const int MOD = 100000000;
    
    int n, m;
    int map_limit[MAXN]; // 地形限制：第 i 行的二进制表示 (1为可种，0为不可种)
    long long dp[MAXN][1 << MAXN]; // dp[i][state]: 第 i 行状态为 state 时的方案数
    vector<int> valid_states; // 预处理出的单行合法状态

    void solve() {
        // 1. 预处理单行合法状态 (没有相邻的草)
        for (int s = 0; s < (1 << m); s++) {
            if (!BitUtils::has_adjacent_ones(s)) {
                valid_states.push_back(s);
            }
        }

        // 2. 初始化第一行
        for (int state : valid_states) {
            // 检查地形：state 必须是 map_limit[1] 的子集
            // 即：state 中有 1 的地方，map_limit 中必须也是 1
            if ((state & map_limit[1]) == state) {
                dp[1][state] = 1;
            }
        }

        // 3. 逐行递推
        for (int i = 2; i <= n; i++) {
            for (int curr : valid_states) { // 枚举当前行
                if ((curr & map_limit[i]) != curr) continue; // 地形检查

                for (int prev : valid_states) { // 枚举上一行
                    if ((prev & map_limit[i-1]) != prev) continue; // 地形检查(可选)

                    // 核心转移：上下行不能有相邻的草 (按位与为 0)
                    if ((curr & prev) == 0) {
                        dp[i][curr] = (dp[i][curr] + dp[i-1][prev]) % MOD;
                    }
                }
            }
        }
        
        // 4. 统计答案
        long long ans = 0;
        for (int state : valid_states) {
            if ((state & map_limit[n]) == state)
                ans = (ans + dp[n][state]) % MOD;
        }
        cout << "Corn Fields Ans: " << ans << endl;
    }
}

// ======================================================================================
// 模块三：进阶棋盘模型 - 多行依赖 (滚动数组)
// 典型例题：P2704 [NOI2001] 炮兵阵地
// 题目概要：炮兵攻击范围是 2 格。当前行受 i-1 和 i-2 行制约。
// ======================================================================================

namespace ArtilleryPosition {
    int N, M;
    int terrain[105]; // 地形压缩 (1为平原可放，0为山地不可放)
    
    // dp[row][curr_state][prev_state]
    // 空间优化：利用滚动数组，第一维只需要开 3 即可
    int dp[3][1024][1024]; 
    vector<int> valid_states;
    int ones_cnt[1024]; // 预处理每个状态放了几个炮兵

    // 检查是否有左右距离 <= 2 的炮兵
    bool check_self(int x) {
        return !((x & (x << 1)) || (x & (x << 2)));
    }

    void solve() {
        // 1. 预处理
        for (int s = 0; s < (1 << M); s++) {
            if (check_self(s)) {
                valid_states.push_back(s);
                ones_cnt[s] = BitUtils::count_ones(s);
            }
        }

        // 2. DP 过程 (滚动数组)
        for (int i = 0; i < N; i++) { // 0-indexed 行
            for (int curr : valid_states) {
                if ((curr & terrain[i]) != curr) continue; // 地形冲突

                for (int prev : valid_states) {
                    // 边界处理：第0行时 prev 只能是0
                    if (i > 0 && (prev & terrain[i-1]) != prev) continue;
                    if (curr & prev) continue; // 上下冲突

                    for (int pprev : valid_states) {
                        // 边界处理：第0/1行时 pprev 只能是0
                        if (i > 1 && (pprev & terrain[i-2]) != pprev) continue;
                        if (curr & pprev) continue; // 跨两行冲突
                        if (prev & pprev) continue; // (可选)

                        // 状态转移：dp[i] = max(..., dp[i-1] + 当前行数量)
                        int val = (i == 0) ? 0 : dp[(i - 1 + 3) % 3][prev][pprev];
                        dp[i % 3][curr][prev] = max(dp[i % 3][curr][prev], val + ones_cnt[curr]);
                    }
                }
            }
        }

        // 3. 统计答案
        int ans = 0;
        for (int curr : valid_states) {
            for (int prev : valid_states) {
                ans = max(ans, dp[(N - 1) % 3][curr][prev]);
            }
        }
        cout << "Artillery Ans: " << ans << endl;
    }
}

// ======================================================================================
// 模块四：集合/路径类状压 (TSP / Hamiltonian Path)
// 典型例题：P4925, P3092, 旅行商问题
// 核心状态：dp[mask][u] -> mask 表示走过的点集，u 表示当前停留在哪个点
// ======================================================================================

namespace TSP_Model {
    const int MAXN = 20;
    const int INF = 0x3f3f3f3f;
    
    int n;
    int dist[MAXN][MAXN]; // 邻接矩阵
    int dp[1 << MAXN][MAXN]; // dp[mask][u]

    void solve() {
        memset(dp, 0x3f, sizeof(dp)); // 求最小值，初始化为 INF
        
        // 初始化：假设从 0 号点出发
        dp[1][0] = 0; 

        // 1. 枚举状态 (从小到大)
        for (int mask = 1; mask < (1 << n); mask++) {
            // 2. 枚举当前所在的点 u (u 必须在 mask 里)
            for (int u = 0; u < n; u++) {
                if (!((mask >> u) & 1)) continue;

                // 3. 枚举上一个点 v (v 必须也在 mask 里，且 v != u)
                int prev_mask = mask ^ (1 << u); // 移除 u
                if (prev_mask == 0) continue; 

                for (int v = 0; v < n; v++) {
                    if ((prev_mask >> v) & 1) {
                        // 状态转移
                        dp[mask][u] = min(dp[mask][u], dp[prev_mask][v] + dist[v][u]);
                    }
                }
            }
        }
        // 结果通常是 min(dp[(1<<n)-1][i]) for all i
    }
}

