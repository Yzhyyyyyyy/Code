// ==================== 3. 基础模型：棋盘类/单行依赖 ====================
// 经典例题：P1879 [USACO06NOV] Corn Fields (种草)
// 场景：N*M 的网格，某些格子不能放，放了东西不能相邻。
// 策略：一行一行处理，当前行的状态只受上一行限制。

#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;

const int MAXN = 14;
const int MOD = 100000000;

int field[MAXN]; // 预处理每一行的地形限制（1表示能种，0表示不能种 -> 需反转或特定处理）
// dp[i][state]: 第 i 行，状态为 state 时的方案数
long long dp[MAXN][1 << MAXN];
vector<int> valid_states; // 预处理出所有单行合法的状态（没有左右相邻）
int M, N;

// 检查单行状态是否合法（没有相邻的草）
bool check_row(int state) {
return !((state & (state << 1)));
}

// 检查两行之间是否冲突（没有上下相邻的草）
bool check_compatible(int state_curr, int state_prev) {
return !(state_curr & state_prev);
}

void solve_corn_fields() {
// 1. 预处理所有可能的单行合法状态
// 这一步非常重要，能极大减少后续循环次数
for (int s = 0; s < (1 << M); s++) {
if (check_row(s)) {
valid_states.push_back(s);
}
}


// 2. 初始化第一行
for (int state : valid_states) {
    // 检查是否种在了贫瘠土地上 (field[1] 记录了第1行的地形)
    // 假设 field[i] 中 1 代表能种，0 代表不能种
    // 这里的判断逻辑根据题目输入具体调整，通常是 (state & field[i]) == state
    if ((state & field[1]) == state) { 
        dp[1][state] = 1;
    }
}

// 3. 逐行递推
for (int i = 2; i <= N; i++) {
    for (int curr : valid_states) { // 枚举当前行状态
        if ((curr & field[i]) != curr) continue; // 地形限制

        for (int prev : valid_states) { // 枚举上一行状态
            if ((prev & field[i-1]) != prev) continue; // 上一行地形限制(其实上一轮已筛选，可省略)
            
            // 核心转移：如果不冲突，累加方案数
            if (check_compatible(curr, prev)) {
                dp[i][curr] = (dp[i][curr] + dp[i-1][prev]) % MOD;
            }
        }
    }
}
// 4. 统计最后一行所有状态的和
}

// ==================== 4. 进阶模型：多行依赖 (炮兵阵地) ====================
// 经典例题：P2704 [NOI2001] 炮兵阵地
// 难点：炮兵攻击范围是 2 格。当前行不仅受 i-1 行影响，还受 i-2 行影响。
// 解决：状态需要增加一维，或者压缩两行状态。
// 常用定义：dp[i][curr_state][prev_state]
//          表示第 i 行状态为 curr，第 i-1 行状态为 prev 时的最大数量。

int dp_cannon[3][1024][1024]; // 使用滚动数组优化第一维，否则空间爆表
int terrain[105]; // 地形压缩
int ones_cnt[1024]; // 预处理每个状态包含几个1

// 检查单行合法性：炮兵左右攻击范围 2 格
bool check_self_cannon(int x) {
if (x & (x << 1)) return false;
if (x & (x << 2)) return false;
return true;
}

void solve_cannon() {
// ... 预处理 valid_states 和 ones_cnt ...


// 核心循环结构：三层状态枚举
for (int i = 0; i < N; i++) { // 枚举行 (0-indexed)
    for (int curr : valid_states) { // 枚举第 i 行
        if ((curr & terrain[i]) != curr) continue;
        
        for (int prev : valid_states) { // 枚举第 i-1 行
            // 边界判断
            if (i > 0 && (prev & terrain[i-1]) != prev) continue;
            if (curr & prev) continue; // 上下冲突
            
            for (int pprev : valid_states) { // 枚举第 i-2 行
                 // 边界判断
                if (i > 1 && (pprev & terrain[i-2]) != pprev) continue;
                if (curr & pprev) continue; // 跨两行冲突
                if (prev & pprev) continue; // 这是 i-1 和 i-2 的冲突，理论上之前处理过
                
                // 状态转移
                // dp[i%3][curr][prev] = max(..., dp[(i-1+3)%3][prev][pprev] + count_ones(curr));
                int val = (i == 0) ? 0 : dp_cannon[(i - 1 + 3) % 3][prev][pprev];
                dp_cannon[i % 3][curr][prev] = max(dp_cannon[i % 3][curr][prev], val + ones_cnt[curr]);
            }
        }
    }
}
}

// ==================== 5. 集合类/连通性状压 (TSP问题) ====================
// 经典例题：P1896 互不侵犯 (其实是棋盘类)，但此处指 P4925 或 TSP 类问题
// 场景：吃奶酪、旅行商问题、经过所有点的最短路径。
// 状态：dp[mask][u] -> mask 表示已经走过的点集(二进制)，u 表示当前停留在节点 u。

const int MAX_TSP = 20;
int dp_tsp[1 << MAX_TSP][MAX_TSP];
int dist[MAX_TSP][MAX_TSP]; // 距离矩阵

void solve_tsp() {
// 初始化为无穷大
// memset(dp_tsp, 0x3f, sizeof(dp_tsp));


// 假设从 0 点出发，状态为 00...01
dp_tsp[1][0] = 0; 

// 1. 枚举状态 (从小到大，确保子状态先被计算)
for (int state = 1; state < (1 << N); state++) { 
    // 2. 枚举当前所在的点 u
    for (int u = 0; u < N; u++) { 
        if (!((state >> u) & 1)) continue; // 状态里必须包含 u
        
        int prev_state = state ^ (1 << u); // 移除 u 得到上一个状态
        if (prev_state == 0) continue; 
        
        // 3. 枚举上一个点 v
        for (int v = 0; v < N; v++) { 
            if ((prev_state >> v) & 1) {
                dp_tsp[state][u] = min(dp_tsp[state][u], dp_tsp[prev_state][v] + dist[v][u]);
            }
        }
    }
}
}

